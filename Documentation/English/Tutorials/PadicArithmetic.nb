   3.8843882320503902`*^9, 
   3.884388232894167*^9}},ExpressionUUID->"b9c8ee94-0887-4b08-999d-\
cffd61672bfa"],

Cell[BoxData[
 RowBox[{
  RowBox[{"0", "<=", 
   RowBox[{
    RowBox[{
     SubscriptBox[
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["b", "0"], 
        SubscriptBox["b", "1"], 
        SubscriptBox["b", "2"], 
        SubscriptBox["\[Ellipsis]b", 
         RowBox[{"k", "-", "1"}]]}], ")"}], "p"], " ", 
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["p", "0"], "+", 
       SuperscriptBox["p", "k"], "+", 
       SuperscriptBox["p", 
        RowBox[{"2", "k"}]], "+", "\[Ellipsis]", "+", 
       SuperscriptBox["p", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"m", " ", "-", "1"}], ")"}], "k"}]]}], ")"}]}], "+", 
    RowBox[{
     SuperscriptBox["p", 
      RowBox[{"m", " ", "k"}]], 
     SubscriptBox[
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["b", "0"], 
        SubscriptBox["b", "1"], 
        SubscriptBox["b", "2"], 
        SubscriptBox["\[Ellipsis]b", "n"]}], ")"}], "p"]}], "-", "N"}]}], "=", 
  SubscriptBox[
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["a", "0"], 
     SubscriptBox["a", "1"], 
     SubscriptBox["a", "2"], 
     SubscriptBox["\[Ellipsis]a", 
      RowBox[{"j", "-", "1"}]]}], ")"}], "p"]}]], "DisplayFormula",
