Cell["\<\
And can produce an overflow situation! However, if we start we a purely \
periodic expansion of (-r) and then negate it\
\>", "Text",
 CellChangeTimes->{{3.884139063913213*^9, 3.8841391310876913`*^9}, {
   3.8841394034329443`*^9, 3.884139436653371*^9}, {3.884139488135891*^9, 
   3.884139495403384*^9}, {3.884139534862445*^9, 3.884139543122429*^9}, {
   3.884141528698702*^9, 3.8841415688458443`*^9}, 3.8841416014472437`*^9, {
   3.88414252043582*^9, 3.884142525459364*^9}, {3.884142595812096*^9, 
   3.884142612006106*^9}, {3.884263545382299*^9, 3.884263548694641*^9}, {
   3.8842751673482428`*^9, 3.884275232797845*^9}, {3.8842761873888206`*^9, 
   3.884276208916486*^9}, {3.884276274795024*^9, 3.884276315695178*^9}, {
   3.88435605908834*^9, 3.884356094758636*^9}, {3.884356177913547*^9, 
   3.884356208364286*^9}, {3.884356666038151*^9, 3.884356706167889*^9}, {
   3.884356749428011*^9, 3.8843567874121857`*^9}, {3.884358027209999*^9, 
   3.8843580402032747`*^9}, {3.884358168239747*^9, 3.884358169353108*^9}, {
   3.884358210987802*^9, 
   3.884358252203471*^9}},ExpressionUUID->"179ada64-4912-43b3-9e9e-\
c76f519ee7dd"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"-", "r"}], ")"}], "=", 
      RowBox[{
       RowBox[{
        RowBox[{"-", 
         SubscriptBox[
          RowBox[{"(", 
           RowBox[{
            SubscriptBox["a", "0"], 
            SubscriptBox["a", "1"], 
            SubscriptBox["a", "2"], 
            SubscriptBox["\[Ellipsis]a", 
             RowBox[{"k", "-", "1"}]]}], ")"}], "p"]}], 
        FractionBox["1", 
         RowBox[{
          SuperscriptBox["p", "k"], "-", "1"}]]}], "=", 
       RowBox[{
        SubscriptBox[
         RowBox[{"(", 
          RowBox[{
           SubscriptBox["a", "0"], 
           SubscriptBox["a", "1"], 
           SubscriptBox["a", "2"], 
           SubscriptBox["\[Ellipsis]a", 
            RowBox[{"k", "-", "1"}]]}], ")"}], "p"], 
        RowBox[{"(", 
         RowBox[{
          SuperscriptBox["p", "0"], "+", 
          SuperscriptBox["p", "k"], "+", 
          SuperscriptBox["p", 
           RowBox[{"2", "k"}]], "+", "\[Ellipsis]"}], ")"}]}]}]}], "\[IndentingNewLine]", 
     RowBox[{"r", "=", 
      RowBox[{"1", "+", 
       RowBox[{"(", 
        RowBox[{"-", "1"}], ")"}], "-", 
       RowBox[{"(", 
        RowBox[{"-", "r"}], ")"}]}]}], "\[IndentingNewLine]", 
     RowBox[{"=", 
      RowBox[{
       RowBox[{"[", 
        RowBox[{"1", "+", 
         RowBox[{"(", 
          RowBox[{"p", "-", "1"}], ")"}], "-", 
         SubscriptBox["a", "0"]}], "]"}], "+", 
       RowBox[{"p", 
        SubscriptBox[
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"[", 
             RowBox[{"p", "-", "1", "-", 
              SubscriptBox["a", "1"]}], "]"}], "[", 
            RowBox[{"p", "-", "1", "-", 
             SubscriptBox["a", "2"]}], "]"}], 
           RowBox[{
            RowBox[{"\[Ellipsis]", "[", 
             RowBox[{"p", "-", "1", "-", 
              SubscriptBox["a", 
               RowBox[{"k", "-", "1"}]]}], "]"}], "[", 
            RowBox[{"p", "-", "1", "-", 
             SubscriptBox["a", "0"]}], "]"}]}], ")"}], "p"], 
        RowBox[{"(", 
         RowBox[{
          SuperscriptBox["p", "0"], "+", 
          SuperscriptBox["p", "k"], "+", 
          SuperscriptBox["p", 
           RowBox[{"2", "k"}]], "+", "\[Ellipsis]"}], ")"}]}]}]}], "\[IndentingNewLine]", 
     RowBox[{"=", 
      RowBox[{
       RowBox[{"[", 
        RowBox[{"p", "-", 
         SubscriptBox["a", "0"]}], "]"}], "+", 
       RowBox[{"p", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           UnderoverscriptBox["\[Sum]", 
            RowBox[{"j", "=", "0"}], 
            RowBox[{"k", "-", "2"}]], 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"p", "-", "1", "-", 
              SubscriptBox["a", 
               RowBox[{"j", "+", "1"}]]}], ")"}], 
            SuperscriptBox["p", "j"]}]}], "+", " ", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"p", "-", "1", "-", 
             SubscriptBox["a", "0"]}], ")"}], 
           SuperscriptBox["p", 
            RowBox[{"k", "-", "1"}]]}]}]}]}]}]}]}], "]"}], ")"}], 
  RowBox[{"(", 
   RowBox[{
    SuperscriptBox["p", "0"], "+", 
    SuperscriptBox["p", "k"], "+", 
    SuperscriptBox["p", 
     RowBox[{"2", "k"}]], "+", "\[Ellipsis]"}], ")"}]}], "\[IndentingNewLine]", 
 RowBox[{"=", 
  RowBox[{
   RowBox[{"[", 
    RowBox[{"p", "-", 
     SubscriptBox["a", "0"]}], "]"}], "+", 
   RowBox[{
    RowBox[{"p", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"p", "-", "1"}], ")"}], 
       FractionBox[
        RowBox[{
         SuperscriptBox["p", "k"], "-", "1"}], 
        RowBox[{"p", "-", "1"}]]}], "-", 
      SubscriptBox[
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["a", "1"], 
         SubscriptBox["a", "2"], 
         SubscriptBox["a", "3"], 
         SubscriptBox["\[Ellipsis]a", 
          RowBox[{"k", "-", "1"}]], 
         SubscriptBox["a", "0"]}], ")"}], "p"]}], "]"}], 
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox["p", "0"], "+", 
      SuperscriptBox["p", "k"], "+", 
      SuperscriptBox["p", 
       RowBox[{"2", "k"}]], "+", "\[Ellipsis]"}], ")"}]}]}]}], "\[IndentingNewLine]", 
 RowBox[{"=", 
  RowBox[{
   RowBox[{"[", 
    RowBox[{"p", "-", 
     SubscriptBox["a", "0"]}], "]"}], "+", 
   RowBox[{"p", " ", 
    RowBox[{"Mod", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "1"}], "-", 
       SubscriptBox[
        RowBox[{"(", 
         RowBox[{
          SubscriptBox["a", "1"], 
          SubscriptBox["a", "2"], 
          SubscriptBox["a", "3"], 
          SubscriptBox["\[Ellipsis]a", 
           RowBox[{"k", "-", "1"}]], 
          SubscriptBox["a", "0"]}], ")"}], "p"]}], ",", 
      SuperscriptBox["p", "k"]}], "]"}], 
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox["p", "0"], "+", 
      SuperscriptBox["p", "k"], "+", 
      SuperscriptBox["p", 
       RowBox[{"2", "k"}]], "+", "\[Ellipsis]"}], ")"}]}]}]}], "\[IndentingNewLine]", 
 RowBox[{"=", 
  RowBox[{
   RowBox[{"[", 
    RowBox[{"p", "-", 
     SubscriptBox["a", "0"]}], "]"}], "-", 
   RowBox[{"p", " ", 
    FractionBox[
     RowBox[{"Mod", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "1"}], "-", 
        SubscriptBox[
         RowBox[{"(", 
          RowBox[{
           SubscriptBox["a", "1"], 
           SubscriptBox["a", "2"], 
           SubscriptBox["a", "3"], 
           SubscriptBox["\[Ellipsis]a", 
            RowBox[{"k", "-", "1"}]], 
           SubscriptBox["a", "0"]}], ")"}], "p"]}], ",", 
       SuperscriptBox["p", "k"]}], "]"}], 
     RowBox[{
      SuperscriptBox["p", "k"], "-", "1"}]]}]}]}]}], "DisplayFormula",
 CellChangeTimes->{{3.883596514029295*^9, 3.883596639671094*^9}, {
