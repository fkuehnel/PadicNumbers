Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox[
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["a", "0"], 
      SubscriptBox["a", "1"], 
      SubscriptBox["a", "2"], "\[Ellipsis]", " ", 
      SubscriptBox["a", 
       RowBox[{"k", "-", "1"}]]}], ")"}], "p"], "=", 
   RowBox[{
    UnderoverscriptBox["\[Sum]", 
     RowBox[{"j", "=", "0"}], 
     RowBox[{"k", "-", "1"}]], 
    RowBox[{
     SubscriptBox["a", "j"], 
     SuperscriptBox["p", "j"]}]}]}], ",", " ", 
  RowBox[{"r", "=", 
   RowBox[{
    RowBox[{
     SubscriptBox[
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["a", "0"], 
        SubscriptBox["a", "1"], 
        SubscriptBox["a", "2"], "\[Ellipsis]", " ", 
        SubscriptBox["a", 
         RowBox[{"k", "-", "1"}]]}], ")"}], "p"], 
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["p", "0"], "+", 
       SuperscriptBox["p", "k"], "+", 
       SuperscriptBox["p", 
        RowBox[{"2", "k"}]], "+", "\[Ellipsis]"}], ")"}]}], "=", 
    RowBox[{
     RowBox[{"-", 
      SubscriptBox[
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["a", "0"], 
         SubscriptBox["a", "1"], 
         SubscriptBox["a", "2"], "\[Ellipsis]", " ", 
         SubscriptBox["a", 
          RowBox[{"k", "-", "1"}]]}], ")"}], "p"]}], 
     FractionBox["1", 
      RowBox[{
       SuperscriptBox["p", "k"], "-", 
       "1"}]]}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.883596514029295*^9, 3.883596639671094*^9}, {
  3.883596683629942*^9, 3.8835966935909863`*^9}, {3.883597004726803*^9, 
  3.883597064326984*^9}, {3.883664441049026*^9, 3.8836644746443853`*^9}, {
  3.883664508782503*^9, 3.883664673641151*^9}, {3.884064087371461*^9, 
  3.884064098761088*^9}, {3.88426245577595*^9, 3.884262473520092*^9}, {
