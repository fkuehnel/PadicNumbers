Cell[CellGroupData[{

Cell[TextData[{
 "Case 2b, negating purely periodic expansion: ",
 StyleBox["r",
  FontSlant->"Italic"],
 " is a positive rational in (0,1) with absolute value 1"
}], "Subsubsection",
 CellChangeTimes->{{3.884139023502275*^9, 3.884139055219236*^9}, {
   3.88413910997898*^9, 3.884139111909546*^9}, {3.884139360922867*^9, 
