  "],ExpressionUUID->"cd9e75aa-95a6-4017-9695-d723df163fbe"],

Cell[TextData[{
 "with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"j", "=", 
    RowBox[{
     RowBox[{"m", " ", "k"}], "+"}]}], TraditionalForm]],ExpressionUUID->
  "1f464900-f776-47a9-b43f-63e76b5d8d19"],
