Cell[TextData[{
 "That is the non-repeating part of length ",
 Cell[BoxData[
  FormBox["j", TraditionalForm]],ExpressionUUID->
  "22c54e68-b3cb-4ecc-857c-9397360313a9"],
 " and hence the periodic part is rotated to the left n-times"
}], "Text",
 CellChangeTimes->{{3.8841733906746683`*^9, 3.8841734582038593`*^9}, {
  3.884212928676064*^9, 3.884212966850099*^9}, {3.884388347854083*^9, 
