Cell[TextData[{
 "For a faithful representation of any rational number ",
 Cell[BoxData[
  FormBox[
   RowBox[{"r", "\[Element]", " "}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "41618fbd-7b4d-470b-8eeb-37a2f5f04bca"],
 "\[DoubleStruckCapitalQ] in its p-adic expansion ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"\[DoubleStruckCapitalQ]", " "}], "p"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "297eac83-85b2-4082-afae-05f4784776f2"],
 " we need to know three parts:\n\n1.) The index of the first non-zero \
coefficient in the expansion (this can be a negative one), this is given by \
",
 StyleBox["PadicOrder",
  FontSlant->"Italic"],
 "\n2.) The non-repeating  part, we call this mantissa here.\n3.) The length \
of the periodicity and the value of the periodic part."
}], "Text",
 CellChangeTimes->{
  3.883596984713049*^9, {3.883597104260064*^9, 3.8835971066853647`*^9}, {
   3.883597200822399*^9, 3.883597259278998*^9}, {3.883614480440296*^9, 
