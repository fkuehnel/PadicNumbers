133b1dd51c69"],

Cell[TextData[{
 "and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "<=", "a", "<", "p"}], TraditionalForm]],ExpressionUUID->
  "3b1e5215-70ae-4993-a677-754e73ea2eb7"],
 ". Further ",
 Cell[BoxData[
  FormBox[
   RowBox[{"a", ",", "q", ",", "u"}], TraditionalForm]],ExpressionUUID->
  "0c47ca40-c203-48a9-8a8d-d6806d978b66"],
 " are uniquely determined! As an example, to determine the unique factor we \
can use the following for the example with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"r", "=", 
    FractionBox["1", "3"]}], TraditionalForm]],ExpressionUUID->
  "3dd622af-1c33-4111-a8ce-48f0ddaac940"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", "=", "5"}], TraditionalForm]],ExpressionUUID->
  "549a89cf-470a-4c5f-a1cf-bb677a472f55"],
 " "
}], "Text",
 CellChangeTimes->{{3.883588671155416*^9, 3.883588746920639*^9}, {
