Cell[TextData[{
 "Mathematica implements rational numbers in such a way that numerator and \
denominator are made co-prime, hence they don\[CloseCurlyQuote]t have any \
common factors.  Further, in order to ensure co-primality with regards to the \
base ",
 Cell[BoxData[
  FormBox["p", TraditionalForm]],ExpressionUUID->
  "014c754d-501a-4c8e-96bc-7cd700f3602b"],
 " we simply use the ",
 StyleBox["PadicNormalize",
  FontSlant->"Italic"],
 " function:"
}], "Text",
 CellChangeTimes->{{3.8841276302751293`*^9, 3.884127780025758*^9}, {
  3.884262293343465*^9, 
  3.884262305908663*^9}},ExpressionUUID->"52252437-dc4c-4f64-8ee1-\
efcb386cab80"],

