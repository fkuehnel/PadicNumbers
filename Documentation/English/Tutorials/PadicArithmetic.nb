     RowBox[{
      RowBox[{"3", "/", "11"}], ",", "5"}], "]"}], "*", 
    RowBox[{"Padic", "[", 
     RowBox[{"417", ",", "5"}], "]"}]}], ",", " ", 
   RowBox[{"Padic", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"3", "/", "11"}], "*", "417"}], ",", "5"}], "]"}], ",", " ", 
   RowBox[{
    RowBox[{"Padic", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"3", "/", "11"}], "*", "417"}], ",", "5"}], "]"}], "//", 
    "FullForm"}], " ", ",", 
   RowBox[{
    RowBox[{"Padic", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"3", "/", "11"}], "*", "417"}], ",", "5"}], "]"}], "//", 
    "Normal"}]}], " ", "}"}]], "Input",
 CellChangeTimes->{{3.981742234832526*^9, 3.981742256334256*^9}, {
