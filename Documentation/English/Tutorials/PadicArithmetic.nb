Cell[TextData[{
 "Applying (1) iteratively leads to a potentially infinite but eventually \
periodic formal power series for a rational number in p-adic expansion, and \
to a finite expansion when the ",
 Cell[BoxData[
  FormBox["r", TraditionalForm]],ExpressionUUID->
  "841f99ba-a385-467e-a2e2-5194edba6ec5"],
 " is a ",
 StyleBox["positive",
  FontWeight->"Bold"],
 " integer (then this is just the regular base p expansion):"
}], "Text",
 CellChangeTimes->{{3.883588671155416*^9, 3.883588746920639*^9}, {
   3.883590327980171*^9, 3.883590395466159*^9}, {3.883596678662175*^9, 
   3.883596753406681*^9}, {3.8835969250643177`*^9, 3.883596975934772*^9}, {
   3.8835974366789303`*^9, 3.883597470039239*^9}, {3.883617837388619*^9, 
   3.883617878971874*^9}, {3.8836604359430847`*^9, 3.883660436920149*^9}, 
   3.883665272778655*^9, {3.8840634679710913`*^9, 3.8840634843030567`*^9}, {
   3.884132590005114*^9, 3.884132608581237*^9}, {3.884262333241753*^9, 
   3.884262402881434*^9}, {3.9814682874928007`*^9, 
   3.981468289617511*^9}},ExpressionUUID->"9e6079d4-d025-46e8-a8bd-\
73e53067fb60"],

Cell[BoxData[
 RowBox[{"r", "=", 
  RowBox[{
   UnderoverscriptBox["\[Sum]", 
    RowBox[{"j", "=", "k"}], "\[Infinity]"], 
   RowBox[{
    SubscriptBox["a", "j"], 
    SuperscriptBox["p", "j"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.883596514029295*^9, 3.883596639671094*^9}, {
