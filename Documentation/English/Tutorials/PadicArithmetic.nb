Cell[CellGroupData[{

Cell[TextData[{
 "A faithful representation of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[DoubleStruckCapitalQ]", "\[Subset]", 
    SubscriptBox["\[DoubleStruckCapitalQ]", "p"]}], TraditionalForm]],
  ExpressionUUID->"037d1482-c6a4-45ed-af28-c67434b56ad9"]
}], "Subsection",
 CellChangeTimes->{{3.884132692121129*^9, 3.884132697753636*^9}, {
  3.884214445997992*^9, 3.884214449830534*^9}, {3.884262239479947*^9, 
  3.884262241787993*^9}, {3.973817822566403*^9, 3.9738178436522818`*^9}, {
  3.9814030176015043`*^9, 3.98140307155125*^9}, {3.981727531881028*^9, 
  3.981727533028077*^9}},ExpressionUUID->"acb0e726-e980-4f52-8505-\
3e03d3a47879"],

Cell[TextData[{
 "Given any prime number ",
 Cell[BoxData[
  FormBox["p", TraditionalForm]],ExpressionUUID->
  "dc52f1d7-0999-4e61-bf4b-36171b3ac50b"],
 ", then with B\[EAcute]zout\[CloseCurlyQuote]s identity or what Mathematica \
calls extended GCD, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"x", " ", "d"}], "+", 
     RowBox[{"y", " ", "p"}]}], "=", "1"}], TraditionalForm]],ExpressionUUID->
  "1b408ad8-a3a0-41e5-b999-5d0b78ab9bc2"],
 " for co-prime ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"gcd", "(", 
     RowBox[{"d", ",", " ", "p"}], ")"}], " ", "=", " ", "1"}], 
   TraditionalForm]],ExpressionUUID->"b8ad739b-d92d-4141-b627-4e05f20739fb"],
 ", there is a unique series expansion in powers of ",
 Cell[BoxData[
  FormBox["p", TraditionalForm]],ExpressionUUID->
  "bf0f7959-9bf1-4e49-a32e-bead2bc131d7"],
 " to positive (infinite) orders. This construction is based on writing a \
rational number with co-prime numerator ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", " "}], TraditionalForm]],ExpressionUUID->
  "0635e468-8ee6-4f77-8257-6a369c133bdb"],
 "and denominator ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "4df3b7af-a131-4a31-8cdb-c7d9ac0bc7c2"],
 " as"
}], "Text",
 CellChangeTimes->{{3.883588671155416*^9, 3.883588746920639*^9}, {
  3.883590327980171*^9, 3.883590395466159*^9}, {3.883591818322834*^9, 
  3.883591819790243*^9}, {3.883591923455187*^9, 3.883592017082699*^9}, {
  3.883596465446466*^9, 3.8835964957580137`*^9}, {3.8835966626182337`*^9, 
  3.883596669992859*^9}, {3.884063784387123*^9, 3.884063784861104*^9}, {
  3.884127078647567*^9, 3.884127271473151*^9}, {3.884127414477916*^9, 
  3.88412754758331*^9}, {3.884128264846941*^9, 
  3.884128274826818*^9}},ExpressionUUID->"a06ae6cd-63e8-4081-aad0-\
503dfc2bb074"],

Cell[BoxData[
 RowBox[{"r", "=", 
  RowBox[{
   RowBox[{
    SuperscriptBox["p", "k"], 
    FractionBox["n", "d"]}], "=", 
   RowBox[{
    RowBox[{
     SuperscriptBox["p", "k"], 
     FractionBox["n", "d"], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"t", " ", "d"}], "+", 
       RowBox[{"u", " ", "p"}]}], ")"}]}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"a", " ", 
       SuperscriptBox["p", "k"]}], "+", 
      RowBox[{
       SuperscriptBox["p", 
        RowBox[{"k", "+", "1"}]], 
       FractionBox[
        RowBox[{
         RowBox[{"q", " ", "d"}], "+", 
         RowBox[{"u", " ", "n"}]}], "d"]}]}], "=", 
     RowBox[{
      RowBox[{"a", " ", 
       SuperscriptBox["p", "k"]}], "+", 
      RowBox[{
       SuperscriptBox["p", 
        RowBox[{"k", "+", "1"}]], 
       FractionBox[
        SuperscriptBox["n", "'"], "d"]}]}]}]}]}]}]], "DisplayFormulaNumbered",\

 CellChangeTimes->{{3.883596514029295*^9, 3.883596639671094*^9}, {
