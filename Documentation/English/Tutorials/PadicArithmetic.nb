ffc34344d6a7"]
}, Closed]],

Cell[CellGroupData[{

Cell["Negation process for integers and general rational numbers", \
"Subsubsection",
 CellChangeTimes->{{3.884354022553381*^9, 3.8843540454287243`*^9}, {
  3.884385070218471*^9, 
  3.884385070783663*^9}},ExpressionUUID->"e9c19e68-b1e2-4c43-a7af-\
c422313c9b9d"],

Cell[TextData[{
 "Now, we can formalize this process in from of negation, consider the \
expansion of a positive integer ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"-", "r"}], ")"}], TraditionalForm]],ExpressionUUID->
  "61d2234a-538d-42a5-a80a-4c4d7d6c83c4"],
 " and write it in 2 ways,"
}], "Text",
 CellChangeTimes->{{3.884139063913213*^9, 3.8841391310876913`*^9}, {
   3.8841394034329443`*^9, 3.884139436653371*^9}, {3.884139488135891*^9, 
   3.884139495403384*^9}, {3.884139534862445*^9, 3.884139543122429*^9}, {
   3.884141528698702*^9, 3.8841415688458443`*^9}, 3.8841416014472437`*^9, {
   3.88414252043582*^9, 3.884142525459364*^9}, {3.884142595812096*^9, 
   3.884142612006106*^9}, {3.884263545382299*^9, 3.884263548694641*^9}, {
   3.884276434461615*^9, 3.884276439187871*^9}, {3.884276825807342*^9, 
   3.884276956627644*^9}, {3.8843533938897963`*^9, 
   3.8843534006928263`*^9}},ExpressionUUID->"f49b9ed5-b3d4-4114-b63b-\
0a669acc319a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"-", "r"}], "=", 
  RowBox[{
   RowBox[{
    SubscriptBox[
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["a", "0"], 
       SubscriptBox["a", "1"], 
       SubscriptBox["a", "2"], 
       SubscriptBox["\[Ellipsis]a", 
        RowBox[{"k", "-", "1"}]]}], ")"}], "p"], " ", "and", " ", "r"}], "=", 
   
   RowBox[{
    RowBox[{"-", 
     RowBox[{"(", 
      RowBox[{"-", "r"}], ")"}]}], "=", 
    RowBox[{
     SubscriptBox[
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["c", "0"], 
        SubscriptBox["c", "1"], 
        SubscriptBox["c", "2"], 
        SubscriptBox["\[Ellipsis]c", 
         RowBox[{"k", "-", "1"}]]}], ")"}], "p"], "+", 
     RowBox[{
      SuperscriptBox["p", "k"], 
      RowBox[{
       SubscriptBox[
        RowBox[{"(", 
         RowBox[{"p", "-", "1"}], ")"}], "p"], "/", 
       RowBox[{"(", 
        RowBox[{"1", "-", "p"}], ")"}]}]}]}]}]}]}]], "DisplayFormula",
 CellChangeTimes->{{3.883596514029295*^9, 3.883596639671094*^9}, {
  3.883596683629942*^9, 3.8835966935909863`*^9}, {3.883597004726803*^9, 
  3.883597064326984*^9}, {3.883664441049026*^9, 3.8836644746443853`*^9}, {
  3.883664508782503*^9, 3.883664673641151*^9}, {3.884064087371461*^9, 
  3.884064098761088*^9}, {3.884139168430571*^9, 3.884139194646338*^9}, {
  3.884213631842987*^9, 3.884213641023918*^9}, {3.884261747794219*^9, 
  3.8842617481940727`*^9}, {3.884262716121269*^9, 3.884262722019458*^9}, {
  3.884262884461375*^9, 3.884262922195252*^9}, {3.8842769784996147`*^9, 
  3.884276982130865*^9}, {3.884277072706298*^9, 3.884277088199011*^9}, {
  3.884277155455715*^9, 
  3.884277155787472*^9}},ExpressionUUID->"23cb14ba-0eb0-4ba5-b7a5-\
ab8dfebc91b4"],

Cell["also we can write it another way", "Text",
 CellChangeTimes->{{3.884139063913213*^9, 3.8841391310876913`*^9}, {
   3.8841394034329443`*^9, 3.884139436653371*^9}, {3.884139488135891*^9, 
   3.884139495403384*^9}, {3.884139534862445*^9, 3.884139543122429*^9}, {
   3.884141528698702*^9, 3.8841415688458443`*^9}, 3.8841416014472437`*^9, {
   3.88414252043582*^9, 3.884142525459364*^9}, {3.884142595812096*^9, 
   3.884142612006106*^9}, {3.884263545382299*^9, 3.884263548694641*^9}, {
   3.884276434461615*^9, 3.884276439187871*^9}, {3.884276825807342*^9, 
   3.884276956627644*^9}, {3.8842773867889433`*^9, 3.884277387730739*^9}, {
   3.884353133910151*^9, 3.884353200045953*^9}, 3.8843532660695133`*^9, {
   3.884353404708663*^9, 
   3.884353414723599*^9}},ExpressionUUID->"a898f67c-dc46-4e3c-baf2-\
872154f35698"],

Cell[BoxData[
 RowBox[{"r", "=", 
  RowBox[{
   RowBox[{"1", "+", 
    RowBox[{"(", 
     RowBox[{"-", "1"}], ")"}], "-", 
    RowBox[{"(", 
     RowBox[{"-", "r"}], ")"}]}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"[", 
      RowBox[{"1", "+", 
       RowBox[{"(", 
        RowBox[{"p", "-", "1"}], ")"}], "-", 
       SubscriptBox["a", "0"]}], "]"}], 
     SuperscriptBox["p", "0"]}], "+", 
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"j", "=", "1"}], 
      RowBox[{"k", "-", "1"}]], 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"p", "-", "1", "-", 
        SubscriptBox["a", "j"]}], ")"}], 
      SuperscriptBox["p", "j"]}]}], "+", 
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"j", "=", "k"}], "\[Infinity]"], 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"p", "-", "1"}], ")"}], 
      SuperscriptBox["p", "j"]}]}]}]}]}]], "DisplayFormula",
 CellChangeTimes->CompressedData["
1:eJxTTMoPSmViYGCQBGIQ/ee9Q0z8+zeOsyq/ZoPoGo2SQhAd83JTEYj+4Th9
JoheXsa1EETPn6jY3gCkz80L6QbRLlwz+0G0f4vJEhDN9Pj1KucPbxyvRkWs
AdG2x3lDMoD02XUh4SD6wM9f63uA9IfDChtBtF1Wpd4SIH3DtA1MFzxsXg6i
0+Y7rADR0w737QHRjfZuB8Hq/vjPWw2keQyOgOl/M8VWgWifOLY1INpiat4W
EP3DqBJM+6SEXALRB3KPXwfRwa8T7oLoLbPz7oHo3ea/X4DoSx/ZX4Noq/Kv
vmuAdNZtDT8Qbf3w2lYQbXQgdSeIFqwrOAiiBRZLHwHR39f/vHYBSOu4xF0H
0SJvvW6D6EAh4zsg+vSE6Y9A9IPG8tcgWuBFyUcQbebA/RNE/1klynQRZM/s
46wgGgAw7vVF
  "],ExpressionUUID->"44331a99-a0c9-4c36-a5b8-8dd29591b97f"],

Cell["Hence, we identity", "Text",
 CellChangeTimes->{{3.884139063913213*^9, 3.8841391310876913`*^9}, {
   3.8841394034329443`*^9, 3.884139436653371*^9}, {3.884139488135891*^9, 
   3.884139495403384*^9}, {3.884139534862445*^9, 3.884139543122429*^9}, {
   3.884141528698702*^9, 3.8841415688458443`*^9}, 3.8841416014472437`*^9, {
   3.88414252043582*^9, 3.884142525459364*^9}, {3.884142595812096*^9, 
   3.884142612006106*^9}, {3.884263545382299*^9, 3.884263548694641*^9}, {
   3.884276434461615*^9, 3.884276439187871*^9}, {3.884276825807342*^9, 
   3.884276956627644*^9}, {3.8842773867889433`*^9, 3.884277387730739*^9}, {
   3.884353133910151*^9, 3.884353200045953*^9}, 3.8843532660695133`*^9, {
   3.884353404708663*^9, 3.884353414723599*^9}, {3.88435362026514*^9, 
   3.884353625503454*^9}},ExpressionUUID->"478a9f45-f0d3-4060-9d2e-\
07fd7b98730a"],

Cell[BoxData[{
 RowBox[{
  SubscriptBox["c", "0"], "=", 
  RowBox[{
   RowBox[{"p", "-", 
    RowBox[{
     SubscriptBox["a", "0"], "   ", "and", "  ", 
     SubscriptBox["c", "j"]}]}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"p", "-", "1"}], ")"}], "-", 
     RowBox[{
      SubscriptBox["a", "j"], " ", "for", " ", "j"}]}], ">=", 
    RowBox[{"1", " ", "or", " ", "equivalently"}]}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  SubscriptBox[
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["c", "0"], 
     SubscriptBox["c", "1"], 
     SubscriptBox["c", "2"], 
     SubscriptBox["\[Ellipsis]c", 
      RowBox[{"k", "-", "1"}]]}], ")"}], "p"], " ", "=", " ", 
  RowBox[{
   RowBox[{"1", "+", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"p", "-", "1"}], ")"}], 
     FractionBox[
      RowBox[{
       SuperscriptBox["p", "k"], "-", "1"}], 
      RowBox[{"p", "-", "1"}]]}], "-", 
    SubscriptBox[
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["a", "0"], 
       SubscriptBox["a", "1"], 
       SubscriptBox["a", "2"], 
       SubscriptBox["\[Ellipsis]a", 
        RowBox[{"k", "-", "1"}]]}], ")"}], "p"]}], "=", 
   RowBox[{
    RowBox[{
     SuperscriptBox["p", "k"], "-", 
     SubscriptBox[
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["a", "0"], 
        SubscriptBox["a", "1"], 
        SubscriptBox["a", "2"], 
        SubscriptBox["\[Ellipsis]a", 
         RowBox[{"k", "-", "1"}]]}], ")"}], "p"]}], "=", 
    RowBox[{"Mod", "[", 
     RowBox[{
      RowBox[{"-", 
       SubscriptBox[
        RowBox[{"(", 
         RowBox[{
          SubscriptBox["a", "0"], 
          SubscriptBox["a", "1"], 
          SubscriptBox["a", "2"], 
          SubscriptBox["\[Ellipsis]a", 
           RowBox[{"k", "-", "1"}]]}], ")"}], "p"]}], ",", 
      SuperscriptBox["p", "k"]}], "]"}]}]}]}]}], "DisplayFormula",
 CellChangeTimes->{{3.883596514029295*^9, 3.883596639671094*^9}, {
   3.883596683629942*^9, 3.8835966935909863`*^9}, {3.883597004726803*^9, 
   3.883597064326984*^9}, {3.883664441049026*^9, 3.8836644746443853`*^9}, {
   3.883664508782503*^9, 3.883664673641151*^9}, {3.884064087371461*^9, 
   3.884064098761088*^9}, {3.884139168430571*^9, 3.884139194646338*^9}, {
   3.884213631842987*^9, 3.884213641023918*^9}, {3.884261747794219*^9, 
   3.8842617481940727`*^9}, {3.884262716121269*^9, 3.884262722019458*^9}, {
   3.884262884461375*^9, 3.884262922195252*^9}, {3.8842769784996147`*^9, 
   3.884276982130865*^9}, {3.884277072706298*^9, 3.884277088199011*^9}, {
   3.884277155455715*^9, 3.884277155787472*^9}, {3.884353651212668*^9, 
   3.8843537004782867`*^9}, 3.884354437419125*^9, {3.8843544803123302`*^9, 
   3.88435453049605*^9}, {3.884354567710088*^9, 3.884354715639784*^9}, {
   3.884362814314241*^9, 
   3.8843628255849733`*^9}},ExpressionUUID->"02e21192-38b7-41d9-ab93-\
bb9dd06094f7"]
}, Closed]],

Cell[CellGroupData[{

Cell[TextData[{
 "Case 2a, purely periodic expansion: ",
 StyleBox["r",
  FontSlant->"Italic"],
 " is a negative rational in [-1,0) with absolute value 1"
}], "Subsubsection",
 CellChangeTimes->{{3.884139023502275*^9, 3.884139055219236*^9}, {
   3.88413910997898*^9, 3.884139111909546*^9}, {3.884139360922867*^9, 
   3.884139373820158*^9}, {3.8841394613876867`*^9, 3.8841394733655567`*^9}, 
   3.884142288048547*^9, {3.884167816240061*^9, 3.8841678978479223`*^9}, {
   3.8841909136115437`*^9, 3.884190936279957*^9}, {3.884196996486836*^9, 
   3.884197038164362*^9}, {3.884263098906671*^9, 3.884263099439301*^9}, {
   3.884263565882568*^9, 3.884263569170577*^9}, 
   3.8842738681359463`*^9},ExpressionUUID->"e52ae773-4e25-4176-9170-\
7e162c931a98"],

Cell[TextData[{
 StyleBox["Theorem 2. ",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 StyleBox[" A rational number with p-adic absolute value 1 has a purely \
periodic p-adic expansion if and only if it lies in the real interval [\
\[Minus]1, 0).",
  FontSlant->"Italic"]
}], "Text",
 CellChangeTimes->{{3.884212348171376*^9, 3.884212419296103*^9}, {
  3.884263102412796*^9, 
  3.884263104672967*^9}},ExpressionUUID->"e058ffdd-e4cc-4c0a-b92e-\
f9456cbddeab"],

Cell["\<\
We already cleared that any purely periodic p-adic expansion with valuation 1 \
represents a rational number in [-1,0)\
\>", "Text",
 CellChangeTimes->{{3.8841733906746683`*^9, 
  3.8841734582038593`*^9}},ExpressionUUID->"b570b5a3-11ac-4512-9bb0-\
57fbf7220de7"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox[
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["a", "0"], 
      SubscriptBox["a", "1"], 
      SubscriptBox["a", "2"], 
      SubscriptBox["\[Ellipsis]a", 
       RowBox[{"k", "-", "1"}]]}], ")"}], "p"], "=", 
   RowBox[{
    UnderoverscriptBox["\[Sum]", 
     RowBox[{"j", "=", "0"}], 
     RowBox[{"k", "-", "1"}]], 
    RowBox[{
     SubscriptBox["a", "j"], 
     SuperscriptBox["p", "j"]}]}]}], ",", " ", 
  RowBox[{"r", "=", 
   RowBox[{
    RowBox[{
     SubscriptBox[
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["a", "0"], 
        SubscriptBox["a", "1"], 
        SubscriptBox["a", "2"], 
        SubscriptBox["\[Ellipsis]a", 
         RowBox[{"k", "-", "1"}]]}], ")"}], "p"], 
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["p", "0"], "+", 
       SuperscriptBox["p", "k"], "+", 
       SuperscriptBox["p", 
        RowBox[{"2", "k"}]], "+", "\[Ellipsis]"}], ")"}]}], "=", 
    RowBox[{
     RowBox[{"-", 
      SubscriptBox[
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["a", "0"], 
         SubscriptBox["a", "1"], 
         SubscriptBox["a", "2"], 
         SubscriptBox["\[Ellipsis]a", 
          RowBox[{"k", "-", "1"}]]}], ")"}], "p"]}], 
     FractionBox["1", 
      RowBox[{
       SuperscriptBox["p", "k"], "-", "1"}]]}]}]}]}]], "DisplayFormula",
 CellChangeTimes->{{3.883596514029295*^9, 3.883596639671094*^9}, {
  3.883596683629942*^9, 3.8835966935909863`*^9}, {3.883597004726803*^9, 
  3.883597064326984*^9}, {3.883664441049026*^9, 3.8836644746443853`*^9}, {
  3.883664508782503*^9, 3.883664673641151*^9}, {3.884064087371461*^9, 
  3.884064098761088*^9}, {3.884272381001553*^9, 
  3.884272391803131*^9}},ExpressionUUID->"854dec99-6628-424e-8f6f-\
2e4a5992ab13"],

Cell[TextData[{
 "Conversely, we can show that any rational number in [-1,0) leads to such an \
expansion, here is how it goes: Assume that n, d and p are pairwise co-prime, \
with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "<", "n", "<=", "d"}], TraditionalForm]],ExpressionUUID->
  "8a210f14-89b2-471b-84bd-40ca0c93c718"],
 ", hence there is a lowest ",
 Cell[BoxData[
  FormBox["k", TraditionalForm]],ExpressionUUID->
  "51bb3def-38bd-400a-9793-6286512e10b6"],
 " for which ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["p", "k"], "=", 
    RowBox[{"1", " ", "mod", " ", "d"}]}], TraditionalForm]],ExpressionUUID->
  "d02e38c6-48c0-46bf-95f9-e631f1507abb"],
 " \[Equivalent] ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["p", "k"], TraditionalForm]],ExpressionUUID->
  "a05fb810-fe5a-46c7-8c37-6bc78df9d66b"],
 "= 1 + d b"
}], "Text",
 CellChangeTimes->{{3.8841733906746683`*^9, 3.884173496118132*^9}, {
  3.8841840415394297`*^9, 3.884184043845977*^9}, {3.88418846271214*^9, 
  3.884188482705923*^9}, {3.8841904654435387`*^9, 3.8841904681438217`*^9}, {
  3.884190714808712*^9, 3.884190774111948*^9}, {3.8841911389009333`*^9, 
  3.8841911499809217`*^9}, {3.884191682243205*^9, 3.884191714687697*^9}, {
  3.884193486138736*^9, 3.884193487163241*^9}, {3.8842724585748158`*^9, 
  3.884272476726392*^9}, {3.884272508147109*^9, 
  3.884272535583034*^9}},ExpressionUUID->"2c00014d-94a0-4f2f-bf0a-\
8d66b4a2d57a"],

Cell[BoxData[
 RowBox[{" ", 
  RowBox[{
   RowBox[{
    RowBox[{"-", "1"}], "<=", "r"}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"-", 
      FractionBox["n", "d"]}], "==", 
     RowBox[{"-", 
      FractionBox[
       RowBox[{"n", " ", "b"}], 
       RowBox[{"d", " ", "b"}]]}]}], "=", 
    RowBox[{
     RowBox[{"-", 
      FractionBox[
       RowBox[{"n", " ", "b"}], 
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["p", "k"], "-", "1"}], ")"}]]}], "=", 
     RowBox[{
      FractionBox["N", 
       RowBox[{"(", 
        RowBox[{"1", "-", 
         SuperscriptBox["p", "k"]}], ")"}]], "=", 
      RowBox[{
       RowBox[{
        SubscriptBox[
         RowBox[{"(", 
          RowBox[{
           SubscriptBox["a", "0"], 
           SubscriptBox["a", "1"], 
           SubscriptBox["a", "2"], 
           SubscriptBox["\[Ellipsis]a", 
            RowBox[{"k", "-", "1"}]]}], ")"}], "p"], 
        RowBox[{"(", 
         RowBox[{
          SuperscriptBox["p", "0"], "+", 
          SuperscriptBox["p", "k"], "+", 
          SuperscriptBox["p", 
           RowBox[{"2", "k"}]], "+", "\[Ellipsis]"}], ")"}]}], "<", 
       "0"}]}]}]}]}]}]], "DisplayFormula",
 CellChangeTimes->{{3.883596514029295*^9, 3.883596639671094*^9}, {
   3.883596683629942*^9, 3.8835966935909863`*^9}, {3.883597004726803*^9, 
   3.883597064326984*^9}, {3.883664441049026*^9, 3.8836644746443853`*^9}, {
   3.883664508782503*^9, 3.883664673641151*^9}, {3.884064087371461*^9, 
   3.884064098761088*^9}, {3.884188497950293*^9, 3.8841885292574*^9}, 
   3.884190421028349*^9, {3.8841912625092773`*^9, 3.884191265461854*^9}, {
   3.884191299040608*^9, 3.88419132296102*^9}, {3.884191739745131*^9, 
   3.88419180447576*^9}, 3.884193802073642*^9, {3.884193985920602*^9, 
   3.8841939951634483`*^9}, 3.88419428842791*^9, {3.8842105571780024`*^9, 
   3.8842105888450203`*^9}, {3.884272410720825*^9, 
   3.884272411159212*^9}},ExpressionUUID->"b356c50b-4ae5-49fe-8e40-\
b821dacdb2e5"],

Cell[TextData[{
 "We could do an exhaustive search for the exponent ",
 Cell[BoxData[
  FormBox["k", TraditionalForm]],ExpressionUUID->
  "1f7b44a0-314b-4523-b0b0-64ae0e3d6af0"],
 " (is there an upper limit on k?), an example for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"-", 
    FractionBox["5", "11"]}], TraditionalForm]],ExpressionUUID->
  "ef9bc6f6-80a0-4c62-a689-ab058e958b2d"],
 "in 3-adic expansion",
 "\n",
 "Also since ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"-", "1"}], "<=", "N"}], "=", 
    RowBox[{
     RowBox[{"n", " ", "b"}], " ", "<", " ", 
     RowBox[{
      SuperscriptBox["p", "k"], "-", "1"}]}]}], TraditionalForm]],
  ExpressionUUID->"4bba41e6-1caa-48b9-8cc9-409b58a3fd47"],
 " we just have a simple integer expansion in base-p at most of length ",
 StyleBox["k with ",
  FontSlant->"Italic"],
 Cell[BoxData[
  RowBox[{"N", "=", 
   SubscriptBox[
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["a", "0"], 
      SubscriptBox["a", "1"], 
      SubscriptBox["a", "2"], 
      SubscriptBox["\[Ellipsis]a", 
       RowBox[{"k", "-", "1"}]]}], ")"}], "p"]}]],
  CellChangeTimes->{{3.883596514029295*^9, 3.883596639671094*^9}, {
    3.883596683629942*^9, 3.8835966935909863`*^9}, {3.883597004726803*^9, 
    3.883597064326984*^9}, {3.883664441049026*^9, 3.8836644746443853`*^9}, {
    3.883664508782503*^9, 3.883664673641151*^9}, {3.884064087371461*^9, 
    3.884064098761088*^9}, {3.884188497950293*^9, 3.8841885292574*^9}, 
    3.884190421028349*^9, {3.8841912625092773`*^9, 3.884191265461854*^9}, {
