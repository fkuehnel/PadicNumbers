Cell[BoxData[{
 RowBox[{
  RowBox[{"mDpN", "=", 
   RowBox[{
    RowBox[{"Mod", "[", 
     RowBox[{
      RowBox[{"5", "*", 
       RowBox[{"PowerMod", "[", 
        RowBox[{"11", ",", 
         RowBox[{"-", "1"}], ",", 
         RowBox[{"3", "^", "7"}]}], "]"}]}], ",", 
      RowBox[{"3", "^", "7"}]}], "]"}], "/", 
    RowBox[{"3", "^", "7"}]}]}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"=", 
    RowBox[{"1591", "/", "2187"}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"ContinuedFractionApprox", "[", 
   RowBox[{
    RowBox[{"mDpN", "*", 
     RowBox[{"3", "^", "7"}]}], ",", 
    RowBox[{"3", "^", "7"}]}], "]"}], "             ", 
  RowBox[{"(*", " ", 
   RowBox[{"=", 
    RowBox[{"{", 
     RowBox[{"2", ",", "1", ",", "2"}], "}"}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"FromContinuedFraction", "[", 
   RowBox[{"{", 
    RowBox[{"2", ",", "1", ",", "2"}], "}"}], "]"}], 
  "                               ", 
  RowBox[{"(*", " ", 
   RowBox[{"=", 
    RowBox[{"8", "/", "3"}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"ContinuedFraction", "[", "mDpN", "]"}], 
  "                                                  ", 
  RowBox[{"(*", " ", 
   RowBox[{"=", 
    RowBox[{"{", 
     RowBox[{
     "0", ",", "1", ",", "2", ",", "1", ",", "2", ",", "39", ",", "2", ",", 
      "2"}], "}"}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"FromContinuedFraction", "[", "%", "]"}], 
  "                                                ", 
  RowBox[{"(*", " ", 
