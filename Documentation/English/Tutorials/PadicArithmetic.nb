Cell[CellGroupData[{

Cell["The Basics", "Section",
 CellChangeTimes->{{3.981641243497213*^9, 
  3.981641248529101*^9}},ExpressionUUID->"b5f7264f-59ab-4957-8c3a-\
08929cd7d4b2"],

Cell[CellGroupData[{

Cell["Everything follows from the PadicOrder (Valuation)", "Subsection",
 CellChangeTimes->{{3.884132692121129*^9, 3.884132697753636*^9}, {
  3.884214445997992*^9, 3.884214449830534*^9}, {3.884262239479947*^9, 
  3.884262241787993*^9}, {3.973817822566403*^9, 3.9738178436522818`*^9}, {
  3.9814030176015043`*^9, 3.98140307155125*^9}, {3.981727511352315*^9, 
  3.981727523315836*^9}, {3.981731165027669*^9, 
  3.981731169213892*^9}},ExpressionUUID->"b7242056-e6f8-4945-b615-\
824d15baa6a8"],

Cell[TextData[{
 "Everything in p-adic arithmetic rests on one question: given a rational \
number and a prime p, how many times does p divide it? \nThis count is called \
the p-adic order (or valuation), written ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Nu]", "p"], TraditionalForm]],ExpressionUUID->
  "92f8b60e-bd64-4659-98f9-b04cf7978a27"],
 ". From it, everything else follows. The p-adic absolute value is p raised \
to the negative order:"
}], "Text",
 CellChangeTimes->{{3.981639061154924*^9, 3.981639084176972*^9}, {
  3.9816395743389*^9, 
  3.9816396021205177`*^9}},ExpressionUUID->"ea75a746-3e93-4b34-96fb-\
dc08d3ad8fe9"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"75", " ", "=", " ", 
    RowBox[{"3", " ", "\[Times]", " ", 
     SuperscriptBox["5", "2"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "848a929a-5381-4b14-bf2d-7ed02037daee"],
 ", so ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Nu]", "5"], "(", "75", ")"}], "=", "2"}], 
   TraditionalForm]],ExpressionUUID->"fe50de8c-1c48-4ab5-949d-f13231e6f82c"],
 ". The number 7 has no factors of 5, so ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Nu]", "5"], "(", "7", ")"}], "=", "20"}], 
   TraditionalForm]],ExpressionUUID->"0ddbc98d-b91d-49ef-b5db-6995d3d10e5d"],
 ". And ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"3", "/", "25"}], "=", 
   RowBox[{"3", "\[Times]", 
    SuperscriptBox["5", 
     RowBox[{"-", "2"}]]}]}]],ExpressionUUID->
  "fcbc5042-3c7b-4a9b-bb03-0b12f603917f"],
 ", so its order is -2. The pattern: positive order means p divides the \
number, negative means p is in the denominator, zero means p is absent \
entirely."
}], "Text",
 CellChangeTimes->{
  3.981639543476317*^9, {3.9816397539501867`*^9, 3.981639772379118*^9}, {
   3.9816419458346443`*^9, 3.981641994117749*^9}, {3.981672549454184*^9, 
   3.9816725495873938`*^9}, {3.981672988836128*^9, 3.9816730136058493`*^9}, {
   3.9816730900244303`*^9, 
   3.981673161969054*^9}},ExpressionUUID->"37cc8426-3c41-4829-b219-\
3932a6e0e143"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"PadicOrder", "[", 
    RowBox[{"75", ",", "5"}], "]"}], ",", 
   RowBox[{"PadicOrder", "[", 
    RowBox[{"7", ",", "5"}], "]"}], ",", 
   RowBox[{"PadicOrder", "[", 
    RowBox[{
     RowBox[{"3", "/", "25"}], ",", "5"}], "]"}]}], "}"}]], "Input",
 CellChangeTimes->{{3.9816731876321697`*^9, 3.981673240361182*^9}},
 CellLabel->"In[4]:=",ExpressionUUID->"667acd43-01d9-4d09-b8e2-77b3bed1cfa7"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"2", ",", "0", ",", 
   RowBox[{"-", "2"}]}], "}"}]], "Output",
 CellChangeTimes->{3.981673241162056*^9, 3.981729098624715*^9, 
  3.981733911189081*^9},
 CellLabel->"Out[4]=",ExpressionUUID->"46a57318-505b-40c7-b627-bb32b63afeaa"]
}, Open  ]],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   SubscriptBox["v", "p"], 
   RowBox[{"(", "n", ")"}]}], "=", 
  TagBox[GridBox[{
     {"\[Piecewise]", GridBox[{
        {
         RowBox[{"max", 
          RowBox[{"{", 
           RowBox[{"k", "\[Element]", 
            RowBox[{"\[DoubleStruckCapitalN]", ":", 
             RowBox[{
              SuperscriptBox["p", "k"], "|", "n"}]}]}], "}"}]}], 
         RowBox[{"n", "!=", "0"}]},
        {"\[Infinity]", 
         RowBox[{"n", "=", "0"}]}
       },
       AllowedDimensions->{2, Automatic},
       Editable->True,
       GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
       GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{1.}}},
       GridBoxSpacings->{"Columns" -> {
           Offset[0.27999999999999997`], {
            Offset[0.84]}, 
           Offset[0.27999999999999997`]}, "Rows" -> {
           Offset[0.2], {
            Offset[0.4]}, 
           Offset[0.2]}},
       Selectable->True]}
    },
    GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
    GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{1.}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.35]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}],
   "Piecewise",
   DeleteWithContents->True,
   Editable->False,
   SelectWithContents->True,
   Selectable->False,
   StripWrapperBoxes->True]}], "\[IndentingNewLine]", "with", "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    SubscriptBox["v", "p"], 
    RowBox[{"(", "n", ")"}]}], "<=", 
   StyleBox[
    RowBox[{
     SubscriptBox[
      StyleBox["log",
       FontSlant->"Italic"], "p"], "n"}],
    FontSlant->"Italic"]}], 
  StyleBox[",",
   FontSlant->"Italic"], 
  StyleBox[" ",
   FontSlant->"Italic"], 
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["v",
      FontSlant->"Italic"], "p"], 
    RowBox[{"(", 
     FractionBox["n", "d"], ")"}]}], "=", 
   RowBox[{
    RowBox[{
     SubscriptBox["v", "p"], 
     RowBox[{"(", "n", ")"}]}], "-", 
    RowBox[{
     SubscriptBox["v", "p"], 
     RowBox[{"(", "d", ")"}]}]}]}]}], "\[IndentingNewLine]", 
 RowBox[{"also", " ", "with", " ", "the", " ", "following", " ", 
  "properties"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   SubscriptBox["\[Nu]", "p"], 
   RowBox[{"(", 
    RowBox[{"x", " ", "\[CenterDot]", "y"}], ")"}]}], "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     SubscriptBox["\[Nu]", "p"], 
     RowBox[{"(", "x", " ", ")"}]}], "+", 
    RowBox[{
     SubscriptBox["\[Nu]", "p"], 
     RowBox[{"(", "y", ")"}], " ", "and", " ", 
     SubscriptBox["\[Nu]", "p"], 
     RowBox[{"(", 
      RowBox[{"x", " ", "+", "y"}], ")"}]}]}], ">=", 
   RowBox[{"min", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[Nu]", "p"], 
       RowBox[{"(", "x", " ", ")"}]}], ",", 
      RowBox[{
       SubscriptBox["\[Nu]", "p"], 
       RowBox[{"(", "y", ")"}]}]}], "}"}], " ", "with", " ", "strict", " ", 
    "equality", " ", "iff", " ", "x"}], "!=", "y"}]}]}], "DisplayFormula",
 CellChangeTimes->{{3.884184340965773*^9, 3.88418437339155*^9}, {
   3.884188698606069*^9, 3.884188761869488*^9}, {3.884188794317851*^9, 
   3.884188957681368*^9}, {3.884189534070818*^9, 3.8841895351796503`*^9}, {
   3.884189572547785*^9, 3.8841896118961763`*^9}, {3.884189974520021*^9, 
   3.884190007283125*^9}, 3.884214458753579*^9, {3.884262100888186*^9, 
   3.884262116030426*^9}, {3.884271057140965*^9, 3.884271071444914*^9}, {
   3.884352801667675*^9, 3.884352845103117*^9}, {3.8843529067590017`*^9, 
   3.88435295889508*^9}, {3.981731226262568*^9, 
   3.9817312406089573`*^9}},ExpressionUUID->"10ea59e5-3d23-42e9-b1fa-\
151bd1c4e248"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"0", "<=", 
   SubscriptBox[
    RowBox[{"\[LeftBracketingBar]", "x", "\[RightBracketingBar]"}], "p"]}], "=", 
  RowBox[{
   RowBox[{
    SuperscriptBox["p", 
     RowBox[{
      RowBox[{"-", 
       SubscriptBox["\[Nu]", "p"]}], 
      RowBox[{"(", "x", " ", ")"}]}]], "<", 
    RowBox[{"\[Infinity]", " ", "and", " ", "0"}]}], "=", 
   RowBox[{
    RowBox[{
     SubscriptBox[
      RowBox[{"\[LeftBracketingBar]", "x", "\[RightBracketingBar]"}], "p"], " ",
      "iff", " ", "x"}], " ", "=", " ", "0"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"hence", " ", "the", " ", "following", " ", "properties", " ", 
  "hold"}], "\[IndentingNewLine]", 
 RowBox[{
  SubscriptBox[
   RowBox[{"\[LeftBracketingBar]", 
    RowBox[{"x", " ", "\[CenterDot]", "y"}], "\[RightBracketingBar]"}], "p"], 
  "=", 
  RowBox[{
   SubscriptBox[
    RowBox[{"\[LeftBracketingBar]", "x", " ", "\[RightBracketingBar]"}], "p"], 
   SubscriptBox[
    RowBox[{"\[LeftBracketingBar]", "y", "\[RightBracketingBar]"}], 
    "p"]}]}], "\[IndentingNewLine]", 
 RowBox[{
  SubscriptBox[
   RowBox[{"\[LeftBracketingBar]", 
    RowBox[{"x", " ", "+", "y"}], "\[RightBracketingBar]"}], "p"], "<=", 
  RowBox[{"max", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox[
      RowBox[{"\[LeftBracketingBar]", "x", " ", "\[RightBracketingBar]"}], 
      "p"], ",", 
     SubscriptBox[
      RowBox[{"\[LeftBracketingBar]", "y", "\[RightBracketingBar]"}], "p"]}], 
    "}"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"and", " ", "with", " ", "it", " ", "the", " ", "non"}], "-", 
  RowBox[{
  "archimedian", " ", "shift", " ", "invariant", " ", "distance"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dist", 
   RowBox[{"(", 
    RowBox[{"x", ",", "y"}], ")"}]}], "=", 
  SubscriptBox[
   RowBox[{"\[LeftBracketingBar]", 
    RowBox[{"x", " ", "-", "y"}], "\[RightBracketingBar]"}], "p"]}], "\[IndentingNewLine]", 
 RowBox[{"and", " ", "the", " ", "triangle", " ", "inequality"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dist", 
   RowBox[{"(", 
    RowBox[{"x", ",", "z"}], ")"}]}], "<=", 
  RowBox[{
   RowBox[{"dist", 
    RowBox[{"(", 
     RowBox[{"x", ",", "y"}], ")"}]}], "+", 
   RowBox[{"dist", 
    RowBox[{"(", 
     RowBox[{"y", ",", "z"}], ")"}]}]}]}]}], "DisplayFormula",
