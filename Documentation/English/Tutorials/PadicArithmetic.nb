Cell[CellGroupData[{

Cell[TextData[{
 "Beautiful formatting of rationals in ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[DoubleStruckCapitalQ]", "p"], TraditionalForm]],
  ExpressionUUID->"b25e5a94-e32e-4f18-bf66-068a21308bd4"],
 " (p-adic Hensel notation)"
}], "Section",
 CellChangeTimes->{{3.884132781115539*^9, 3.884132829920547*^9}, 
   3.884133207102502*^9, {3.8842145015657377`*^9, 3.884214502399993*^9}, {
   3.88436113337167*^9, 3.884361149429008*^9}, {3.981493178817072*^9, 
   3.9814932032855463`*^9}, {3.981736696055085*^9, 
   3.9817366973534803`*^9}},ExpressionUUID->"b621f9ff-c35a-4435-ad2a-\
f6dcdb151b66"],

Cell["\<\
P-adic Hensel notation displays p-adic numbers as digit strings with a base \
subscript, read left-to-right from highest to lowest power of p. Digits shown \
in amber with an overbar are the periodic block \[LongDash] they repeat \
infinitely to the left. Non-periodic digits appear in the default color to \
the right of the overbar. A subscripted dot marks the boundary between \
non-negative and negative powers of p, analogous to a decimal point but \
separating p-adic \[OpenCurlyDoubleQuote]integers\[CloseCurlyDoubleQuote] \
from \[OpenCurlyDoubleQuote]fractional\[CloseCurlyDoubleQuote] parts. When \
the exponent e exceeds the display threshold, the notation factors out p^e \
explicitly (e.g., 32\:2087 \[Times] 7\:2075). Zero is shown as 0 with a base \
subscript. For example, 6\:03045555\:2087 reads as ...666655557 \[LongDash] \
the overbarred 6 repeats forever to the left, followed by the four \
non-periodic digits 5555, all in base 7. The Normal value in each output \
confirms the rational number this expansion represents.\
\>", "Text",
 CellChangeTimes->{
  3.9817443755132113`*^9},ExpressionUUID->"a6c1ea2d-08d5-4ff6-978e-\
fa0685f9d525"],

