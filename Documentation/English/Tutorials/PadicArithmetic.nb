Cell[TextData[{
 "Hence, we can implement a simple rotate left operation that leaves the \
length of the periodicity unchanged. ",
 StyleBox["RotateLeft",
  FontSlant->"Italic"],
 " does this for the internal ",
 StyleBox["PadicRationalNaive",
  FontSlant->"Italic"],
 " representation"
}], "Text",
 CellChangeTimes->{{3.884139063913213*^9, 3.8841391310876913`*^9}, {
