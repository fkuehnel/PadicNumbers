     RowBox[{"k", ",", 
      RowBox[{"Mod", "[", 
       RowBox[{
        RowBox[{"-", "1"}], ",", 
        RowBox[{"3", "^", "k"}]}], "]"}], ",", 
      RowBox[{"Mod", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Mod", "[", 
          RowBox[{
           RowBox[{"-", "1"}], ",", 
           RowBox[{"3", "^", "k"}]}], "]"}], "+", "1"}], ",", 
        RowBox[{"3", "^", "k"}]}], "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"k", ",", "1", ",", "8"}], "}"}]}], "]"}], "//", 
  "TableForm"}]], "Input",
