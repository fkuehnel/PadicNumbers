Cell[BoxData[
 RowBox[{" ", 
  RowBox[{"r", "=", 
   RowBox[{
    RowBox[{
     SubscriptBox[
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["a", "0"], 
        SubscriptBox["a", "1"], 
        SubscriptBox["a", "2"], 
        SubscriptBox["\[Ellipsis]a", 
         RowBox[{"j", "-", "1"}]]}], ")"}], "p"], "+", 
     RowBox[{
      SuperscriptBox["p", "j"], 
      SubscriptBox[
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["a", "j"], 
         SubscriptBox["a", 
          RowBox[{"j", "+", "1"}]], 
         SubscriptBox["a", 
          RowBox[{"j", "+", "2"}]], 
         SubscriptBox["\[Ellipsis]a", 
          RowBox[{"j", "+", "k", "-", "1"}]]}], ")"}], "p"], 
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox["p", "0"], "+", 
        SuperscriptBox["p", "k"], "+", 
        SuperscriptBox["p", 
         RowBox[{"2", "k"}]], "+", "\[Ellipsis]"}], ")"}]}]}], "=", 
    RowBox[{
     SubscriptBox[
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["a", "0"], 
        SubscriptBox["a", "1"], 
        SubscriptBox["a", "2"], 
        SubscriptBox["\[Ellipsis]a", 
         RowBox[{"j", "-", "1"}]]}], ")"}], "p"], "-", 
     RowBox[{
      SuperscriptBox["p", "j"], 
      SubscriptBox[
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["b", "0"], 
         SubscriptBox["b", "1"], 
         SubscriptBox["b", "2"], 
         SubscriptBox["\[Ellipsis]b", 
          RowBox[{"k", "-", "1"}]]}], ")"}], "p"], 
      FractionBox["1", 
       RowBox[{
        SuperscriptBox["p", "k"], "-", "1"}]]}]}]}]}]}]], "DisplayFormula",
 CellChangeTimes->{{3.883596514029295*^9, 3.883596639671094*^9}, {
  3.883596683629942*^9, 3.8835966935909863`*^9}, {3.883597004726803*^9, 
  3.883597064326984*^9}, {3.883664441049026*^9, 3.8836644746443853`*^9}, {
  3.883664508782503*^9, 3.883664673641151*^9}, {3.883664893025782*^9, 
  3.883665000985948*^9}, {3.8836650444589787`*^9, 3.883665052042808*^9}, {
  3.8840640697584*^9, 3.884064080173833*^9}, {3.88421285147473*^9, 
  3.884212884332026*^9}, {3.884272613971958*^9, 3.884272631420411*^9}, {
  3.884272757524378*^9, 
  3.88427276394788*^9}},ExpressionUUID->"7b5e1873-7c0e-42a7-a21d-\
89c861146407"],

Cell["\<\
Separating the non-periodic and periodic parts introduces code complexity. We \
reduce this by combining both into a single significand. PadicRational[m, p, \
e, N, k] is a p-adic floating-point format: m is the significand, e is the \
exponent (valuation), p is the base, N is the total precision (= non-period + \
period length), and k encodes the periodicity. The analogy to IEEE 754\
\[CloseCurlyQuote]s (sign, exponent, mantissa) is natural but richer because \
k captures the exact repeating structure that rationals have.\
\>", "Text",
 CellChangeTimes->{{3.8841733906746683`*^9, 3.884173496118132*^9}, {
   3.8841840415394297`*^9, 3.884184043845977*^9}, {3.88418846271214*^9, 
   3.884188482705923*^9}, {3.8841904654435387`*^9, 3.8841904681438217`*^9}, {
   3.884190714808712*^9, 3.884190774111948*^9}, {3.8841911389009333`*^9, 
   3.8841911499809217`*^9}, {3.884191682243205*^9, 3.884191714687697*^9}, {
   3.884193486138736*^9, 3.884193487163241*^9}, {3.884213001976965*^9, 
   3.884213047217177*^9}, {3.884213702935266*^9, 3.884213703696732*^9}, {
   3.884214662124655*^9, 3.88421467031439*^9}, {3.884385232316906*^9, 
   3.884385253065426*^9}, {3.884385339371716*^9, 3.884385393555365*^9}, {
   3.8843914931732483`*^9, 3.8843915433111677`*^9}, {3.88443786844617*^9, 
   3.884437884504155*^9}, {3.981471746852365*^9, 3.98147176253339*^9}, 
   3.981471815646884*^9, 3.981493399167721*^9, {3.9814942850648413`*^9, 
   3.9814943559287148`*^9}, {3.9814952875899773`*^9, 3.981495288108817*^9}, {
   3.9814993754850397`*^9, 3.981499376610736*^9}, {3.981737132993723*^9, 
   3.981737138667604*^9}},ExpressionUUID->"ddd605be-c8d5-41cc-8f3c-\
4a3865e05f60"],

Cell[TextData[{
 "PadicRational[",
 Cell[BoxData[
  SubscriptBox[
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["a", "0"], 
     SubscriptBox["a", "1"], 
     SubscriptBox["a", "2"], 
     SubscriptBox["\[Ellipsis]a", 
      RowBox[{"j", "-", "1"}]]}], ")"}], "p"]],
  CellChangeTimes->{{3.883596514029295*^9, 3.883596639671094*^9}, {
   3.883596683629942*^9, 3.8835966935909863`*^9}, {3.883597004726803*^9, 
   3.883597064326984*^9}, {3.883664441049026*^9, 3.8836644746443853`*^9}, {
   3.883664508782503*^9, 3.883664673641151*^9}, {3.883664893025782*^9, 
   3.883665000985948*^9}, {3.8836650444589787`*^9, 3.883665052042808*^9}, {
   3.8840640697584*^9, 3.884064080173833*^9}, {3.88421285147473*^9, 
   3.884212884332026*^9}, {3.884272613971958*^9, 3.884272631420411*^9}, {
   3.884272757524378*^9, 3.88427276394788*^9}},ExpressionUUID->
  "3b74bde1-66f6-47ce-b49e-bda9741f379b"],
 "+",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["p", "j"], TraditionalForm]],ExpressionUUID->
  "f1ca9429-b894-4e91-9da2-88686b4aa156"],
 Cell[BoxData[
  SubscriptBox[
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["b", "0"], 
     SubscriptBox["b", "1"], 
     SubscriptBox["b", "2"], 
     SubscriptBox["\[Ellipsis]b", 
      RowBox[{"k", "-", "1"}]]}], ")"}], "p"]],
  CellChangeTimes->{{3.883596514029295*^9, 3.883596639671094*^9}, {
   3.883596683629942*^9, 3.8835966935909863`*^9}, {3.883597004726803*^9, 
   3.883597064326984*^9}, {3.883664441049026*^9, 3.8836644746443853`*^9}, {
   3.883664508782503*^9, 3.883664673641151*^9}, {3.883664893025782*^9, 
   3.883665000985948*^9}, {3.8836650444589787`*^9, 3.883665052042808*^9}, {
   3.8840640697584*^9, 3.884064080173833*^9}, {3.88421285147473*^9, 
   3.884212884332026*^9}, {3.884272613971958*^9, 3.884272631420411*^9}, {
   3.884272757524378*^9, 3.88427276394788*^9}},ExpressionUUID->
  "1e496fce-22db-438c-b91b-9869e101a5f2"],
 ",p,e,N,k] // Normal -> Rational[n,d]  N=j+k\nPadicRational[m,p,e,N,k] // \
Normal -> Mod[m,p^j] - p^j Quotient[m,p^j]/(p^k-1)  N=j+k\n\
PadicRational[m,p,e,N,0] // Normal -> m * p^e"
}], "Program",
 CellChangeTimes->{{3.884385282852954*^9, 3.8843853374180107`*^9}, {
  3.884385410117449*^9, 3.884385503901328*^9}, {3.8843915561707287`*^9, 
  3.884391800234864*^9}, {3.8843919492195*^9, 3.88439195960061*^9}, {
  3.884392010570175*^9, 3.88439213488197*^9}, {3.884392205675349*^9, 
  3.884392218514407*^9}, {3.884437906111321*^9, 3.884437909317924*^9}, {
  3.8844385399653683`*^9, 3.8844386000109463`*^9}, {3.884438639497238*^9, 
  3.884438639892362*^9}, {3.884475878634034*^9, 3.884475909081653*^9}, {
  3.884529908185865*^9, 3.8845299445125113`*^9}, {3.8845623944284773`*^9, 
  3.884562406554447*^9}, {3.8845986308134403`*^9, 3.8845986878156757`*^9}, {
  3.884694527713666*^9, 
  3.884694542338812*^9}},ExpressionUUID->"edd0acdb-24fc-46e1-8bb0-\
4b6cde571af8"],

Cell[CellGroupData[{

Cell["Four Cases of Integer and Rational P-adic Expansions", "Subsection",
 CellChangeTimes->{{3.884138982200831*^9, 3.88413901242428*^9}, {
  3.981738013567913*^9, 
  3.981738036296028*^9}},ExpressionUUID->"946d4abd-812d-4506-b47b-\
31530a83fdba"],

Cell[CellGroupData[{

Cell[TextData[{
 "Case 0: Non-negative integers ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[DoubleStruckCapitalZ]", 
    RowBox[{">=", "0"}]], TraditionalForm]],ExpressionUUID->
  "923da456-3156-433c-9ba3-2fa6c80ad006"]
}], "Subsubsection",
 CellChangeTimes->{{3.884139023502275*^9, 3.884139055219236*^9}, {
   3.88413910997898*^9, 3.884139111909546*^9}, {3.884139445535326*^9, 
   3.8841394786109943`*^9}, 3.884142293333424*^9, {3.884261648075843*^9, 
   3.88426171017454*^9}, {3.9817378193693867`*^9, 
   3.981737827328471*^9}},ExpressionUUID->"95bff01b-85e2-42b1-92c8-\
002a2e4a0320"],

Cell["\<\
The p-adic expansion of a positive integer or 0 is just the regular finite \
base-p expansion:\
\>", "Text",
 CellChangeTimes->{{3.884139063913213*^9, 3.8841391310876913`*^9}, {
  3.884213605078301*^9, 3.8842136096666183`*^9}, {3.88426172239235*^9, 
  3.884261729339715*^9}, {3.8842617636332207`*^9, 3.88426176927699*^9}, {
  3.981737838543511*^9, 
  3.981737839099495*^9}},ExpressionUUID->"bc4cbb82-5caa-497d-8a5d-\
47589a71bb4b"],

Cell[BoxData[
 RowBox[{"r", "=", 
  RowBox[{
   SubscriptBox[
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["a", "0"], 
      SubscriptBox["a", "1"], 
      SubscriptBox["a", "2"], 
      SubscriptBox["\[Ellipsis]a", 
       RowBox[{"k", "-", "1"}]]}], ")"}], "p"], "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"j", "=", "0"}], 
       RowBox[{"k", "-", "1"}]], 
      RowBox[{
       SubscriptBox["a", "j"], 
       SuperscriptBox["p", "j"]}]}], " ", "<", 
     RowBox[{
      SuperscriptBox["p", "k"], " ", "with", " ", "k"}]}], "=", 
    RowBox[{"\[LeftCeiling]", 
     StyleBox[
      RowBox[{
       SubscriptBox[
        StyleBox["log",
         FontSlant->"Italic"], "p"], "[", 
       RowBox[{"-", "r"}], "]"}],
      FontSlant->"Italic"], "\[RightCeiling]"}]}]}]}]], "DisplayFormula",
 CellChangeTimes->{{3.883596514029295*^9, 3.883596639671094*^9}, {
  3.883596683629942*^9, 3.8835966935909863`*^9}, {3.883597004726803*^9, 
  3.883597064326984*^9}, {3.883664441049026*^9, 3.8836644746443853`*^9}, {
  3.883664508782503*^9, 3.883664673641151*^9}, {3.884064087371461*^9, 
  3.884064098761088*^9}, {3.884139168430571*^9, 3.884139194646338*^9}, {
  3.884213631842987*^9, 3.884213641023918*^9}, {3.884261747794219*^9, 
  3.8842617481940727`*^9}, {3.884262716121269*^9, 3.884262722019458*^9}, {
  3.884262884461375*^9, 
  3.884262922195252*^9}},ExpressionUUID->"343233e1-a457-482a-ba81-\
e1e013f6a484"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Case 1: Negative integers (-r > 0)", "Subsubsection",
 CellChangeTimes->{{3.884139023502275*^9, 3.884139055219236*^9}, {
   3.88413910997898*^9, 3.884139111909546*^9}, {3.884139360922867*^9, 
   3.884139373820158*^9}, {3.8841394613876867`*^9, 3.8841394733655567`*^9}, 
   3.884142288048547*^9, {3.884261777299267*^9, 3.8842618115189037`*^9}, {
   3.981737859669156*^9, 
   3.98173786023461*^9}},ExpressionUUID->"9289dfdb-4e0a-4a24-8417-\
0260a6d3358a"],

Cell[TextData[{
 "Since, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"-", "r"}], ")"}], TraditionalForm]],ExpressionUUID->
  "f6e74323-2f5f-45e7-9810-fd8f5e95a886"],
 " is positive and is smaller than some ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["p", "k"], TraditionalForm]],ExpressionUUID->
  "5f95027b-f506-4763-9139-8bd82b407c2b"],
 " we can find a p-adic expansion of  the positive integer ",
 Cell[BoxData[
  FormBox[
   RowBox[{"R", "=", 
    RowBox[{
     SuperscriptBox["p", "k"], "-", 
     RowBox[{"(", 
      RowBox[{"-", "r"}], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "b26fb771-9a5b-4163-8aec-ad112e0e1f61"],
 " as in the case above:"
}], "Text",
 CellChangeTimes->{{3.884139063913213*^9, 3.8841391310876913`*^9}, {
   3.8841394034329443`*^9, 3.884139436653371*^9}, {3.884139488135891*^9, 
   3.884139495403384*^9}, {3.8841395505606813`*^9, 3.884139634821315*^9}, {
   3.884139862536167*^9, 3.8841399351183558`*^9}, {3.8841400633409452`*^9, 
   3.884140087670149*^9}, {3.884140145998954*^9, 3.884140148066964*^9}, {
   3.884141494798579*^9, 3.8841415265199537`*^9}, 3.8841415760370693`*^9, {
   3.8842629893913107`*^9, 3.884263062030115*^9}, {3.8842760579074907`*^9, 
   3.884276069011835*^9}},ExpressionUUID->"7181d130-fbc2-4c1b-8266-\
5d6a93ef86a7"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SuperscriptBox["p", "k"], "-", 
   RowBox[{"(", 
    RowBox[{"-", "r"}], ")"}]}], "=", 
  RowBox[{"R", "=", 
   RowBox[{
    RowBox[{"Mod", "[", 
     RowBox[{"r", ",", 
      SuperscriptBox["p", "k"]}], "]"}], "=", 
    RowBox[{
     SubscriptBox[
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["c", "0"], 
        SubscriptBox["c", "1"], 
        SubscriptBox["c", "2"], 
        SubscriptBox["\[Ellipsis]c", 
         RowBox[{"k", "-", "1"}]]}], ")"}], "p"], "=", 
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"j", "=", "0"}], 
       RowBox[{"k", "-", "1"}]], 
      RowBox[{
       SubscriptBox["c", "j"], 
       SuperscriptBox["p", "j"], " "}]}]}]}]}]}]], "DisplayFormula",
 CellChangeTimes->{{3.883596514029295*^9, 3.883596639671094*^9}, {
   3.883596683629942*^9, 3.8835966935909863`*^9}, {3.883597004726803*^9, 
   3.883597064326984*^9}, {3.883664441049026*^9, 3.8836644746443853`*^9}, {
   3.883664508782503*^9, 3.883664673641151*^9}, {3.884064087371461*^9, 
   3.884064098761088*^9}, {3.884139168430571*^9, 3.884139194646338*^9}, 
   3.8841395018118267`*^9, 3.8841398592094507`*^9, {3.884140106250701*^9, 
   3.884140135058373*^9}, {3.884140212247283*^9, 3.8841402218765*^9}, {
   3.88414160875364*^9, 3.884141663212284*^9}, {3.884263081175198*^9, 
   3.88426308163741*^9}, {3.884276079008066*^9, 
   3.884276080240991*^9}},ExpressionUUID->"44b39c4a-3b0c-461a-b0cc-\
905f33fb5aa7"],

Cell[TextData[{
 "A direct consequence of the formal infinite power series expansion is that \
we have a simple representation for the negative integer -1 and for -",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["p", "k"], TraditionalForm]],ExpressionUUID->
  "f4b955a7-9250-4a43-9e53-c9709b410458"]
}], "Text",
 CellChangeTimes->{
  3.883596984713049*^9, {3.883597104260064*^9, 3.8835971066853647`*^9}, {
   3.883597200822399*^9, 3.883597259278998*^9}, {3.883614480440296*^9, 
   3.8836144855090437`*^9}, {3.883614535507792*^9, 3.883614603494079*^9}, {
   3.883617887981423*^9, 3.883617897506748*^9}, {3.883660422281104*^9, 
   3.883660425382986*^9}, {3.883664360651959*^9, 3.8836644047492113`*^9}, {
   3.883665756321815*^9, 3.883665782335987*^9}, {3.883665861635289*^9, 
   3.883665872952832*^9}, {3.884132709513645*^9, 3.884132764617346*^9}, {
   3.884134472261292*^9, 3.884134473636394*^9}, {3.884137871459093*^9, 
   3.884137903429185*^9}, {3.8842635196397257`*^9, 
   3.8842635213635197`*^9}},ExpressionUUID->"713f6e99-0112-4dbc-920d-\
ab253f705611"],

Cell[BoxData[
 RowBox[{" ", 
  RowBox[{
   RowBox[{"-", "1"}], "=", 
   RowBox[{
    SubscriptBox[
     RowBox[{"(", 
      RowBox[{"p", "-", 
       RowBox[{"1", "p"}], "-", 
       RowBox[{"1", "\[Ellipsis]"}]}], ")"}], "p"], "=", 
    RowBox[{
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"j", "=", "0"}], "\[Infinity]"], 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"p", "-", "1"}], ")"}], 
       SuperscriptBox["p", "j"]}]}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{
        FractionBox[
         RowBox[{"p", "-", "1"}], 
         RowBox[{"1", "-", "p"}]], "  ", "and", " ", "therefor"}], "-", 
       SuperscriptBox["p", "k"]}], "=", 
      RowBox[{
       UnderoverscriptBox["\[Sum]", 
        RowBox[{"j", "=", "k"}], "\[Infinity]"], 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"p", "-", "1"}], ")"}], 
        SuperscriptBox["p", "j"]}]}]}]}]}]}]}]], "DisplayFormula",
 CellChangeTimes->{{3.883596514029295*^9, 3.883596639671094*^9}, {
   3.883596683629942*^9, 3.8835966935909863`*^9}, {3.883597004726803*^9, 
   3.883597064326984*^9}, {3.883664441049026*^9, 3.8836644746443853`*^9}, {
   3.883664508782503*^9, 3.883664673641151*^9}, {3.883664893025782*^9, 
   3.883665000985948*^9}, {3.8836650444589787`*^9, 3.883665052042808*^9}, {
   3.883665784937435*^9, 3.883665853664695*^9}, {3.883669854547205*^9, 
   3.883669922392177*^9}, {3.883670120736293*^9, 3.883670190598484*^9}, {
   3.88367027692688*^9, 3.883670433368245*^9}, {3.883670538652032*^9, 
   3.883670539133214*^9}, {3.883670601419201*^9, 3.8836706398316708`*^9}, {
   3.883670689229559*^9, 3.883670701431919*^9}, 3.88377921904151*^9, {
   3.884134510603601*^9, 3.884134529613103*^9}, {3.884137907441514*^9, 
   3.8841379595290327`*^9}, {3.8842634738039217`*^9, 
   3.884263512765081*^9}},ExpressionUUID->"54c7cc63-3237-43df-bfc8-\
79e668207276"],

Cell["\<\
therefore finally we have the infinite eventually periodic expansion of a \
negative integer\
\>", "Text",
 CellChangeTimes->{{3.884139063913213*^9, 3.8841391310876913`*^9}, {
   3.8841394034329443`*^9, 3.884139436653371*^9}, {3.884139488135891*^9, 
   3.884139495403384*^9}, {3.884139534862445*^9, 3.884139543122429*^9}, {
   3.884141528698702*^9, 3.8841415688458443`*^9}, 3.8841416014472437`*^9, {
   3.88414252043582*^9, 3.884142525459364*^9}, {3.884142595812096*^9, 
   3.884142612006106*^9}, {3.884263545382299*^9, 3.884263548694641*^9}, {
   3.884276434461615*^9, 
   3.884276439187871*^9}},ExpressionUUID->"601ffda9-63dd-4855-ac55-\
241dc3932132"],

Cell[BoxData[
 RowBox[{"r", "=", 
  RowBox[{
   RowBox[{"R", "-", 
    SuperscriptBox["p", "k"]}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["p", "k"], "-", 
       RowBox[{"(", 
        RowBox[{"-", "r"}], ")"}]}], ")"}], "-", 
     SuperscriptBox["p", "k"]}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       UnderoverscriptBox["\[Sum]", 
        RowBox[{"j", "=", "0"}], 
        RowBox[{"k", "-", "1"}]], 
       RowBox[{
        SubscriptBox["c", "j"], 
        SuperscriptBox["p", "j"]}]}], " ", "+", 
      RowBox[{
       UnderoverscriptBox["\[Sum]", 
        RowBox[{"j", "=", "k"}], "\[Infinity]"], 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"p", "-", "1"}], ")"}], 
        SuperscriptBox["p", "j"]}]}]}], "=", 
     RowBox[{
      SubscriptBox[
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["c", "0"], 
         SubscriptBox["c", "1"], 
         SubscriptBox["c", "2"], 
         SubscriptBox["\[Ellipsis]c", 
          RowBox[{"k", "-", "1"}]]}], ")"}], "p"], "+", 
      RowBox[{
       SuperscriptBox["p", "k"], 
       RowBox[{
        SubscriptBox[
         RowBox[{"(", 
          RowBox[{"p", "-", "1"}], ")"}], "p"], "/", 
        RowBox[{"(", 
         RowBox[{"1", "-", "p"}], ")"}]}]}]}]}]}]}]}]], "DisplayFormula",
 CellChangeTimes->{{3.883596514029295*^9, 3.883596639671094*^9}, {
   3.883596683629942*^9, 3.8835966935909863`*^9}, {3.883597004726803*^9, 
   3.883597064326984*^9}, {3.883664441049026*^9, 3.8836644746443853`*^9}, {
   3.883664508782503*^9, 3.883664673641151*^9}, {3.884064087371461*^9, 
   3.884064098761088*^9}, {3.884139168430571*^9, 3.884139194646338*^9}, 
   3.8841395018118267`*^9, 3.8841398592094507`*^9, {3.884140106250701*^9, 
   3.884140135058373*^9}, {3.884140212247283*^9, 3.8841402218765*^9}, {
   3.88414160875364*^9, 3.884141663212284*^9}, {3.8841425389595823`*^9, 
   3.884142585808926*^9}, {3.884276117207279*^9, 3.8842761239738197`*^9}, 
   3.884276613270755*^9, {3.884276669999156*^9, 3.884276698264329*^9}, {
   3.8842767355244827`*^9, 
