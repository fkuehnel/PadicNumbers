Cell[TextData[{
 "The problem with writing it in this way is that the first coefficient \
belonging to the non-periodic part is not guaranteed to be less than ",
 Cell[BoxData[
  FormBox["p", TraditionalForm]],ExpressionUUID->
  "7405bdd7-9f1e-4de2-afbc-57f8e36dfe52"]
}], "Text",
 CellChangeTimes->{{3.884139063913213*^9, 3.8841391310876913`*^9}, {
