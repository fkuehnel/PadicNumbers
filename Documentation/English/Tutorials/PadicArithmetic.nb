   3.8842751673482428`*^9, 3.884275232797845*^9}, {3.884355781973525*^9, 
   3.884355798326721*^9}},ExpressionUUID->"b2de19b2-44b2-4228-b796-\
517abafce754"],

Cell[BoxData[
 RowBox[{"r", "=", 
  RowBox[{
   RowBox[{"1", "+", 
    RowBox[{"(", 
     RowBox[{"r", "-", "1"}], ")"}]}], "=", 
   RowBox[{
    RowBox[{"1", "+", "R"}], "=", 
    RowBox[{
     RowBox[{"1", "+", 
      RowBox[{
       SubscriptBox[
        RowBox[{"(", 
         RowBox[{
          SubscriptBox["c", "0"], 
          SubscriptBox["c", "1"], 
          SubscriptBox["c", "2"], 
          SubscriptBox["\[Ellipsis]c", 
           RowBox[{"k", "-", "1"}]]}], ")"}], "p"], 
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["p", "0"], "+", 
         SuperscriptBox["p", "k"], "+", 
         SuperscriptBox["p", 
          RowBox[{"2", "k"}]], "+", "\[Ellipsis]"}], ")"}]}]}], "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "+", 
        SubscriptBox["c", "0"]}], ")"}], "+", 
      RowBox[{"p", 
       SubscriptBox[
        RowBox[{"(", 
         RowBox[{
          SubscriptBox["c", "1"], 
          SubscriptBox["c", "2"], 
          SubscriptBox["c", "3"], 
          SubscriptBox["\[Ellipsis]c", 
           RowBox[{"k", "-", "1"}]], 
          SubscriptBox["c", "0"]}], ")"}], "p"], 
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["p", "0"], "+", 
         SuperscriptBox["p", "k"], "+", 
         SuperscriptBox["p", 
          RowBox[{"2", "k"}]], "+", "\[Ellipsis]"}], 
        ")"}]}]}]}]}]}]}]], "DisplayFormula",
 CellChangeTimes->{{3.883596514029295*^9, 3.883596639671094*^9}, {
