6417f22ab3c3"],

Cell[BoxData[
 RowBox[{
  SubscriptBox[
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["c", "1"], 
     SubscriptBox["c", "2"], 
     SubscriptBox["c", "3"], 
     SubscriptBox["\[Ellipsis]c", 
      RowBox[{"k", "-", "1"}]]}], ")"}], "p"], ",", 
  RowBox[{
   SubscriptBox["c", "0"], "=", 
   RowBox[{"QuotientRemainder", "[", 
    RowBox[{
     SubscriptBox[
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["c", "0"], 
        SubscriptBox["c", "1"], 
        SubscriptBox["c", "2"], 
        SubscriptBox["\[Ellipsis]c", 
         RowBox[{"k", "-", "1"}]]}], ")"}], "p"], ",", "p"}], 
    "]"}]}]}]], "DisplayFormula",
