Cell[BoxData[
 RowBox[{
  SubscriptBox[
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["c", "1"], 
     SubscriptBox["c", "2"], 
     SubscriptBox["c", "3"], 
     SubscriptBox["\[Ellipsis]c", 
      RowBox[{"k", "-", "1"}]], 
     SubscriptBox["c", "0"]}], ")"}], "p"], "=", 
  RowBox[{"Mod", "[", 
   RowBox[{
