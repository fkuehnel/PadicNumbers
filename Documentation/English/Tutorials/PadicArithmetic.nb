   3.884273909763064*^9}},ExpressionUUID->"169aaf88-35f8-408b-af14-\
e0d217fbfcac"],

Cell[TextData[{
 "There are 2 ways to handle this case, we could write ",
 Cell[BoxData[
  FormBox[
   RowBox[{"R", "=", 
    RowBox[{"r", "-", "1"}]}], TraditionalForm]],ExpressionUUID->
  "95523684-d385-4e08-9006-0a1eca90e406"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"R", " "}], TraditionalForm]],ExpressionUUID->
  "6bf9f88a-427b-421d-8f3e-9f964b21c671"],
 " is a rational for which case 2a applies"
}], "Text",
 CellChangeTimes->{{3.884139063913213*^9, 3.8841391310876913`*^9}, {
   3.8841394034329443`*^9, 3.884139436653371*^9}, {3.884139488135891*^9, 
