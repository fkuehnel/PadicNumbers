        SubscriptBox["a", "0"], 
        SubscriptBox["a", "1"], 
        SubscriptBox["a", "2"], 
        SubscriptBox["\[Ellipsis]a", 
         RowBox[{"j", "-", "1"}]]}], ")"}], "p"], "-", 
     RowBox[{
      SuperscriptBox["p", "j"], 
      SubscriptBox[
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["b", "0"], 
         SubscriptBox["b", "1"], 
         SubscriptBox["b", "2"], 
         SubscriptBox["\[Ellipsis]b", 
          RowBox[{"k", "-", "1"}]]}], ")"}], "p"], 
