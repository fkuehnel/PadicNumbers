Cell[BoxData[
 RowBox[{" ", 
  RowBox[{"r", "=", 
   RowBox[{
    RowBox[{
     SubscriptBox[
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["a", "0"], 
        SubscriptBox["a", "1"], 
        SubscriptBox["a", "2"], 
        SubscriptBox["\[Ellipsis]a", 
         RowBox[{"j", "-", "1"}]]}], ")"}], "p"], "+", 
     RowBox[{
      SuperscriptBox["p", "j"], 
      SubscriptBox[
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["a", "j"], 
         SubscriptBox["a", 
          RowBox[{"j", "+", "1"}]], 
         SubscriptBox["a", 
          RowBox[{"j", "+", "2"}]], 
         SubscriptBox["\[Ellipsis]a", 
          RowBox[{"j", "+", "k", "-", "1"}]]}], ")"}], "p"], 
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox["p", "0"], "+", 
        SuperscriptBox["p", "k"], "+", 
        SuperscriptBox["p", 
         RowBox[{"2", "k"}]], "+", "\[Ellipsis]"}], ")"}]}]}], "=", 
    RowBox[{
     SubscriptBox[
      RowBox[{"(", 
