60ddd07a5253"],

Cell[CellGroupData[{

Cell["The RATCONVERT Algorithm", "Section",
 CellChangeTimes->{{3.9817562986342363`*^9, 3.9817563091220207`*^9}, {
  3.98182132052157*^9, 
  3.981821325755643*^9}},ExpressionUUID->"b40d1cc5-96e6-4f5c-b078-\
74ae47fd46b7"],

Cell[TextData[{
 StyleBox["1. The Algorithm (pseudo-code):  ",
  FontWeight->"Bold"],
 "Wang\[CloseCurlyQuote]s [1981]",
 " algorithm is (we adapt the notation slightly) :",
 StyleBox["\n\nRATCONVERT(m, p\:1d3a)\n[1] v:= (p\:1d3a, 0, 1), w:= (m, 1, 0)\
\n[2] While ", "Program"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    SqrtBox[
     RowBox[{"(", 
      RowBox[{"p\:1d3a", "/", "2"}], ")"}]], "<=", 
    SubscriptBox["w", "1"]}], TraditionalForm]],ExpressionUUID->
  "b13e74a2-b852-489e-b605-40f28849b50d"],
 StyleBox[" do\n[3]   {q:= ", "Program"],
 Cell[BoxData[
  FormBox[
   RowBox[{"\[LeftFloor]", 
    RowBox[{
     SubscriptBox["v", "1"], "/", 
     SubscriptBox["w", "1"]}], "\[RightFloor]"}], TraditionalForm]],
  ExpressionUUID->"2dd08f6c-15b3-4deb-9148-730b613067b4"],
 StyleBox[", r:=v-q\[CenterDot]w, v:=w, w:=r}\n[4] If ", "Program"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[LeftBracketingBar]", 
     SubscriptBox["w", "2"], "\[RightBracketingBar]"}], ">=", 
    SqrtBox[
     RowBox[{"(", 
      RowBox[{"p\:1d3a", "/", "2"}], ")"}]]}], TraditionalForm]],
  ExpressionUUID->"b71cd73c-5b1a-464e-b6d7-1670861f1cf4"],
 " ",
 StyleBox["then error()  (* denominator too large *)\n[5] Return (", 
  "Program"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["w", "1"], "/", 
    SubscriptBox["w", "2"]}], TraditionalForm]],ExpressionUUID->
  "a3ff7557-07dd-4d92-8d40-d4b8db87edcd"],
 StyleBox[")", "Program"]
}], "Text",
 CellChangeTimes->{
  3.88478252736084*^9, {3.884783774208233*^9, 3.884783779552964*^9}, {
   3.8847838433821983`*^9, 3.884783847780428*^9}, {3.884783879284789*^9, 
   3.88478395469489*^9}, {3.884784089930243*^9, 3.884784112421948*^9}, {
   3.884788000002062*^9, 3.884788063443712*^9}, {3.884788150937263*^9, 
   3.884788217656431*^9}, {3.8847920944851723`*^9, 3.884792208952858*^9}, {
   3.884792272145998*^9, 3.8847923814577713`*^9}, {3.981755900985475*^9, 
   3.981755919560457*^9}, {3.981756314857842*^9, 3.98175631650581*^9}, {
   3.9817566061982393`*^9, 3.981756630408846*^9}, {3.981756679446419*^9, 
   3.981756684616804*^9}, {3.981820180905501*^9, 3.9818202679399014`*^9}, {
   3.981820989370319*^9, 3.9818210021253157`*^9}, {3.981821966417058*^9, 
   3.981821975860209*^9}},ExpressionUUID->"0f54117e-b2db-472c-9988-\
c4c3525182b2"],

Cell["The implementation in C++ code", "Text",
 CellChangeTimes->{{3.8850762975971212`*^9, 3.885076303604857*^9}, {
  3.981757632222568*^9, 
  3.981757634460538*^9}},ExpressionUUID->"12deabfe-a172-4bdf-8df0-\
872a734fe4b8"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"//", " ", 
     RowBox[{"https", ":"}]}], "//", 
    RowBox[{
     RowBox[{"godbolt", ".", "org"}], "/"}]}], "\n", "//", " ", 
   RowBox[{"-", "std"}]}], "=", 
  RowBox[{
   RowBox[{"c", "++"}], "11"}]}], "\n", 
 RowBox[{
  RowBox[{
  "#include", " ", "<", "cstdint", ">", "\n", "#include", " ", "<", "cmath", ">",
    "\n", "#include", " ", "<", "tuple", ">", "\n", "\n", 
   RowBox[{"std", "::", "tuple"}], "<", "int64_t"}], ",", " ", 
  RowBox[{"int64_t", ">", " ", 
   RowBox[{"ratconvert", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"int64_t", " ", "m"}], ",", " ", 
      RowBox[{"int64_t", " ", "pN"}]}], ")"}], " ", 
    RowBox[{"{", "\n", "    ", 
     RowBox[{
      RowBox[{
       RowBox[{"int64_t", " ", "v1"}], " ", "=", " ", "pN"}], ",", " ", 
      RowBox[{"v2", " ", "=", " ", "0"}], ",", " ", 
      RowBox[{"w1", " ", "=", " ", "m"}], ",", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"w2", " ", "=", " ", "1"}], ";", "\n", "    ", 
        RowBox[{
         RowBox[{"int64_t", " ", "bnd"}], " ", "=", " ", 
         RowBox[{"sqrt", 
          RowBox[{"(", 
           RowBox[{"pN", " ", "/", " ", "2"}], ")"}]}]}], ";", "\n", "    ", 
        RowBox[{"while", " ", 
         RowBox[{"(", 
          RowBox[{"w1", " ", ">=", " ", "bnd"}], ")"}], " ", 
         RowBox[{"{", "\n", "        ", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"int64_t", " ", "q"}], "  ", "=", " ", 
             RowBox[{"floor", 
              RowBox[{"(", 
               RowBox[{"v1", " ", "/", " ", "w1"}], ")"}]}]}], ";", "\n", 
            "        ", 
            RowBox[{
             RowBox[{"int64_t", " ", "r1"}], " ", "=", " ", 
             RowBox[{"v1", " ", "-", " ", 
              RowBox[{"q", " ", "*", " ", "w1"}]}]}]}], ",", "  ", 
           RowBox[{
            RowBox[{"r2", " ", "=", " ", 
             RowBox[{"v2", " ", "-", " ", 
              RowBox[{"q", " ", "*", " ", "w2"}]}]}], ";", "\n", "        ", 
            RowBox[{"v1", " ", "=", " ", "w1"}], ";", "  ", 
            RowBox[{"v2", " ", "=", " ", "w2"}], ";", "\n", "        ", 
            RowBox[{"w1", " ", "=", " ", "r1"}], ";", "  ", 
            RowBox[{"w2", " ", "=", " ", "r2"}], ";"}]}], "\n", "    ", "}"}],
          "\n", "    ", "if", " ", 
         RowBox[{"(", 
          RowBox[{"w2", " ", ">=", " ", "bnd"}], ")"}], " ", 
         RowBox[{"{", "\n", "        ", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"return", " ", 
              RowBox[{"{", 
               RowBox[{"m", ",", " ", "0"}], "}"}]}], ";"}], " ", "//", " ", 
            RowBox[{"error", ":", " ", 
             RowBox[{
              RowBox[{"no", " ", "rational", " ", "with"}], " ", "|", "u", 
              "|"}]}]}], ",", 
           RowBox[{"|", "v", "|", " ", 
            RowBox[{"<", " ", 
             RowBox[{"\[Sqrt]", 
              RowBox[{"(", 
               RowBox[{"p\:1d3a", "/", "2"}], ")"}]}]}]}]}], "\n", "    ", 
          "}"}], "\n", "    ", "return", " ", 
         RowBox[{"{", 
          RowBox[{"w1", ",", " ", "w2"}], "}"}]}], ";"}], "   ", "//", " ", 
       RowBox[{"u", "/", "v"}]}]}], "\n", "}"}]}]}]}]}], "Code",
 CellChangeTimes->{{3.88497135907933*^9, 3.884971464865996*^9}, {
  3.884971513955076*^9, 3.8849715899800987`*^9}, {3.88497162281129*^9, 
  3.8849716415839643`*^9}, {3.8849717574487257`*^9, 3.8849718478821487`*^9}, {
  3.884971913301276*^9, 3.88497193128104*^9}, {3.884971972207185*^9, 
  3.884972017315515*^9}, {3.884972118538665*^9, 3.884972118845536*^9}, {
  3.8849723451227283`*^9, 3.884972345501069*^9}, {3.8849725293520813`*^9, 
  3.884972534343306*^9}, {3.8849727835247927`*^9, 3.884972783869566*^9}, {
  3.884973193089862*^9, 3.884973193430534*^9}, {3.8849734522491217`*^9, 
  3.884973455760273*^9}, {3.884973552201564*^9, 3.884973574341061*^9}, {
  3.884973834045582*^9, 3.884973879747562*^9}, {3.885076288202222*^9, 
  3.885076288986678*^9}, {3.8850766299994173`*^9, 3.885076669849154*^9}, {
  3.885251593597436*^9, 3.8852515940525217`*^9}, {3.981820421537344*^9, 
  3.981820446504863*^9}},ExpressionUUID->"05ddf526-a6d9-4798-a857-\
410582b4d0c7"],

Cell[CellGroupData[{

Cell["Why this works, what\[CloseCurlyQuote]s behind this algorithm?", \
"Subsection",
 CellChangeTimes->{{3.9817562986342363`*^9, 3.9817563091220207`*^9}, {
  3.98182132052157*^9, 3.981821325755643*^9}, {3.981822048850636*^9, 
  3.981822060088832*^9}},ExpressionUUID->"5ea656dd-b039-4fd1-9517-\
5ea6a6b1d7c7"],

Cell[TextData[{
 "Wang ensures that ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"v", " "}], "2"], TraditionalForm]],ExpressionUUID->
  "22879f5a-6f2c-4b7d-8efe-7168beb98233"],
 " is positive, but we do not need this complication. Throughout the \
iteration, the following equations hold:\n\nv\:2083\[CenterDot]p\:1d3a + v\
\:2082\[CenterDot]m = v\:2081\nw\:2083\[CenterDot]p\:1d3a + w\:2082\
\[CenterDot]m = w\:2081\n\nIf the algorithm terminates successfully, \
w\:2081/w\:2082 \[Congruent] m (mod p\:1d3a) is immediately satisfied by the \
second invariant. What remains to prove is that any solution u/v \[Congruent] \
m (mod p\:1d3a) satisfying |u|, |v| < ",
 Cell[BoxData[
  FormBox[
   SqrtBox[
    RowBox[{"(", 
     RowBox[{"p\:1d3a", "/", "2"}], ")"}]], TraditionalForm]],ExpressionUUID->
  "c314558b-2de2-4b35-8d22-55233a7fd744"],
 " will be found \[LongDash] uniqueness follows from the size bound.\n\n",
 StyleBox["Continued Fractions.",
  FontWeight->"Bold"],
 "\nThe algorithm can be viewed as computing successive rational \
approximations to m/p\:1d3a, since:\n\n\[Minus]w\:2083/w\:2082 = m/p\:1d3a \
\[Minus] w\:2081/(p\:1d3a\[CenterDot]w\:2082)\n\nThe quotients q computed in \
step [3] are precisely the successive terms of the continued fraction \
expansion of m/p\:1d3a (see [Hardy & Wright, 1979] Theorem 161 or Knuth \
[1981] pp. 339-343):"
}], "Text",
 CellChangeTimes->{
  3.88478252736084*^9, {3.884783774208233*^9, 3.884783779552964*^9}, 
   3.8847838433821983`*^9, {3.884783973834618*^9, 3.88478399680987*^9}, {
   3.884788230677512*^9, 3.884788243600871*^9}, 3.8847925675016127`*^9, {
   3.884792620876239*^9, 3.8847926763586683`*^9}, {3.884793019371161*^9, 
   3.884793153284438*^9}, {3.8847932084148207`*^9, 3.884793214053976*^9}, {
   3.884793252051655*^9, 3.8847933347625227`*^9}, 3.884793403549611*^9, {
   3.884793572818577*^9, 3.884793591679605*^9}, {3.884794776270637*^9, 
   3.884794877804718*^9}, {3.8847950075623426`*^9, 3.884795120400334*^9}, {
   3.884795227511087*^9, 3.884795259548877*^9}, {3.884796304425152*^9, 
   3.884796304940444*^9}, 3.88479679859026*^9, {3.884817412929768*^9, 
   3.884817416279646*^9}, {3.981756694616094*^9, 3.981756694730054*^9}, {
   3.981822856094821*^9, 3.9818229619512377`*^9}, {3.9818230122183447`*^9, 
   3.9818230305652523`*^9}},ExpressionUUID->"5f06566c-f230-4c3d-92bf-\
d184a6f62091"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"m", "/", 
   RowBox[{"p", "^", "N"}]}], "==", 
  RowBox[{"1", "/", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"q", "[", "1", "]"}], "+", 
     RowBox[{"1", "/", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"q", "[", "2", "]"}], "+", 
        RowBox[{"1", "/", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"q", "[", "3", "]"}], "+", "\[Ellipsis]"}], ")"}]}]}], 
       ")"}]}]}], ")"}]}]}]], "Input",
 CellChangeTimes->{{3.884817192118462*^9, 3.8848172852949533`*^9}, {
  3.884817488326973*^9, 3.8848175126485147`*^9}, {3.9818231266489983`*^9, 
  3.981823191378036*^9}},
 CellLabel->
  "In[208]:=",ExpressionUUID->"bfa07163-30c7-48bd-ad9f-719bedbb7fab"],

Cell[BoxData[
 RowBox[{
  RowBox[{"m", " ", 
   SuperscriptBox["p", 
    RowBox[{"-", "N"}]]}], "\[Equal]", 
  FractionBox["1", 
   RowBox[{
    RowBox[{"q", "[", "1", "]"}], "+", 
    FractionBox["1", 
     RowBox[{
      RowBox[{"q", "[", "2", "]"}], "+", 
      FractionBox["1", 
       RowBox[{"\[Ellipsis]", "+", 
        RowBox[{"q", "[", "3", "]"}]}]]}]]}]]}]], "Output",
 CellChangeTimes->{
  3.88481749808184*^9, {3.9818231786266947`*^9, 3.981823192218388*^9}},
 CellLabel->
  "Out[208]=",ExpressionUUID->"0288b6ed-8423-4579-9581-cae230fdaa7b"]
}, Open  ]],

Cell[TextData[{
 "After one iteration of step [3]: v\:2082 = 1, w\:2082 = q\:2081, and \
\[Minus]w\:2083/w\:2082 is the second convergent 1/q\:2081 to m/p\:1d3a. The \
recurrence P\:2099\:208a\:2081 = q\[CenterDot]P\:2099 + P\:2099\:208b\:2081 \
is exactly the standard convergent iteration \[LongDash] so the sequence of \
\[Minus]w\:2083/w\:2082 values is the sequence of convergents to m/p\:1d3a. \
The algorithm stops as soon as the denominator crosses ",
 Cell[BoxData[
  FormBox[
   SqrtBox[
    RowBox[{"(", 
     RowBox[{"p\:1d3a", "/", "2"}], ")"}]], TraditionalForm]],ExpressionUUID->
  "ae2460d9-6b65-4c41-811a-69d74c6f40fb"],
 ", guaranteeing the reconstructed u/v is the unique rational within the size \
bound.\n\nAfter one iteration of step [3], we have ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["v", "3"], TraditionalForm]],ExpressionUUID->
  "e4e5e1fa-cd8a-40b2-a1a2-71d45d220ad0"],
 "=0, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["v", "2"], "=", "1"}], TraditionalForm]],ExpressionUUID->
  "ea783f9f-4e19-4436-af71-a1401a434b82"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"-", 
     SubscriptBox["v", "3"]}], "/", 
    SubscriptBox["v", "2"]}], TraditionalForm]],ExpressionUUID->
  "a219af7e-00ab-42f0-9889-e1d414fc2c3c"],
 " is the first approximation (0) to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"c", "/", "m"}], ")"}], TraditionalForm]],ExpressionUUID->
  "4c94270d-913b-4b8a-8933-5a297bceddc6"],
 ",\nand ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["w", "3"], TraditionalForm]],ExpressionUUID->
  "84131ac7-382b-4f28-8919-39f75ab0f66b"],
 "=1, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["w", "2"], "=", 
    SubscriptBox["q", "1"]}], TraditionalForm]],ExpressionUUID->
  "36d38f3e-7720-4009-aa5e-9b47f112bbeb"],
 " and  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"-", 
     SubscriptBox["w", "3"]}], "/", 
    SubscriptBox["w", "2"]}], TraditionalForm]],ExpressionUUID->
  "2cb51aa2-d47f-4419-849a-7df409523d61"],
 " is the second approximation ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"1", "/", 
     SubscriptBox["q", "1"]}], ")"}], TraditionalForm]],ExpressionUUID->
  "fdde29d8-d14c-4b4c-acc7-5baeae088acd"],
 " to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"c", "/", "m"}], ")"}], TraditionalForm]],ExpressionUUID->
  "abdab0e5-4dbc-4207-a78c-33036176ccda"],
 ". The definition of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["w", "3"], ",", 
    SubscriptBox["w", "2"]}], TraditionalForm]],ExpressionUUID->
  "64cc40e1-6646-4fc6-98ed-dcabcdd206c6"],
 "\nin terms of the previours values of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["v", "3"], ",", 
    RowBox[{
     SubscriptBox["v", 
      RowBox[{"2", ","}]], 
     SubscriptBox["w", "3"]}], ",", 
    SubscriptBox["w", "2"]}], TraditionalForm]],ExpressionUUID->
  "d7ddbf73-a9b2-4847-9d8d-fd4343a93f82"],
 " and ",
 Cell[BoxData[
  FormBox["q", TraditionalForm]],ExpressionUUID->
  "ef508b44-3467-4ebf-a725-1f896c2b1124"],
 " is then (after allowing for our different sign convention)\njust the \
standard iteration ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", 
     RowBox[{"n", "+", "1"}]], "=", 
    RowBox[{
     SubscriptBox["qP", "n"], "+", 
     SubscriptBox["P", 
      RowBox[{"n", "-", "1"}]]}]}], TraditionalForm]],ExpressionUUID->
  "c2176b2f-063c-4ace-9278-6dd263449c26"],
 " for computing a convergent in terms of its two immediate\npredecessors. \
Hence we have that the sequence of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"-", 
     SubscriptBox["w", "3"]}], "/", 
    SubscriptBox["w", "2"]}], TraditionalForm]],ExpressionUUID->
  "fb0078f7-97d8-45a6-a7de-42359912d26a"],
 " is the sequence of convergents to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"c", "/", "m"}], ")"}], TraditionalForm]],ExpressionUUID->
  "6e3e57f5-835c-420a-96d1-864ddcc63037"],
 "."
}], "Text",
 CellChangeTimes->{
  3.88478252736084*^9, {3.884783774208233*^9, 3.884783779552964*^9}, 
   3.8847838433821983`*^9, {3.884783973834618*^9, 3.88478399680987*^9}, {
   3.884788230677512*^9, 3.884788243600871*^9}, 3.8847925675016127`*^9, {
   3.884792620876239*^9, 3.8847926763586683`*^9}, {3.884793019371161*^9, 
   3.884793153284438*^9}, {3.8847932084148207`*^9, 3.884793214053976*^9}, {
   3.884793252051655*^9, 3.8847933347625227`*^9}, 3.884793403549611*^9, {
   3.884793572818577*^9, 3.884793591679605*^9}, {3.884794776270637*^9, 
   3.884794877804718*^9}, {3.8847950075623426`*^9, 3.884795120400334*^9}, {
   3.884795227511087*^9, 3.884795259548877*^9}, {3.884796304425152*^9, 
   3.884796304940444*^9}, {3.884816708202722*^9, 3.884816777617649*^9}, {
   3.8848189897149553`*^9, 3.884818991082502*^9}, {3.8848191215671597`*^9, 
   3.884819195467345*^9}, {3.884819272776479*^9, 3.8848192738781767`*^9}, {
   3.884819318787979*^9, 3.884819397588377*^9}, {3.884819428286921*^9, 
   3.884819438635085*^9}, {3.8848194694198017`*^9, 3.8848194837618113`*^9}, {
   3.884868784949718*^9, 3.88486883920853*^9}, {3.884868875259921*^9, 
   3.8848689008432407`*^9}, {3.8848754642170343`*^9, 3.884875596188054*^9}, 
   3.9815011213918953`*^9, {3.981823263504446*^9, 3.981823282067573*^9}, 
   3.981823337968803*^9, {3.981824791344678*^9, 
   3.9818247939556637`*^9}},ExpressionUUID->"9ac19e9e-6ae2-4309-b1d1-\
3fe213c44795"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ContinuedFractionApprox", "[", 
   RowBox[{"m_", ",", "pN_"}], "]"}], ":=", 
  RowBox[{"Last", "/@", 
   RowBox[{"Drop", "[", 
    RowBox[{
     RowBox[{"NestWhileList", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Function", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"v", ",", "w"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"w", ",", 
             RowBox[{"v", "-", 
              RowBox[{
               RowBox[{"Floor", "[", 
                RowBox[{
                 RowBox[{"v", "[", 
                  RowBox[{"[", "1", "]"}], "]"}], "/", 
                 RowBox[{"w", "[", 
                  RowBox[{"[", "1", "]"}], "]"}]}], "]"}], " ", "w"}]}], ",", 
             
             RowBox[{"Floor", "[", 
              RowBox[{
               RowBox[{"v", "[", 
                RowBox[{"[", "1", "]"}], "]"}], "/", 
               RowBox[{"w", "[", 
                RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], "}"}]}], "]"}], "@@",
          "#"}], "&"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"pN", ",", "0", ",", "1"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"m", ",", "1", ",", "0"}], "}"}], ",", "0"}], "}"}], ",", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"#", "[", 
           RowBox[{"[", 
            RowBox[{"2", ",", "1"}], "]"}], "]"}], ">", 
          RowBox[{"Sqrt", "[", 
           RowBox[{"pN", "/", "2"}], "]"}]}], ")"}], "&"}]}], "]"}], ",", 
     "2"}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.884796849227889*^9, 3.884796937871655*^9}, {
   3.884797058210928*^9, 3.884797077482419*^9}, {3.884797213524139*^9, 
   3.884797213699388*^9}, 3.8848168855038433`*^9, {3.8848176537484694`*^9, 
   3.88481766105527*^9}, {3.8848182026591187`*^9, 3.884818202744566*^9}, {
