   3.884386493618166*^9, 
   3.884386498893094*^9}},ExpressionUUID->"5d96d756-110b-4a24-a22c-\
c217c576dffb"],

Cell[TextData[{
 StyleBox["Theorem 3. ",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 StyleBox[" In ",
  FontSlant->"Italic"],
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    StyleBox["Q",
     FontWeight->"Bold"], "p"], TraditionalForm]],ExpressionUUID->
  "58051f3f-fc4a-4c84-ab0d-68cc497890ad"],
 StyleBox[", the numbers with eventually periodic p-adic expansions are \
precisely the rational numbers.",
  FontSlant->"Italic"]
}], "Text",
 CellChangeTimes->{{3.884212348171376*^9, 3.8842124350308437`*^9}, {
  3.884212470258073*^9, 3.884212493562315*^9}, {3.884265829929248*^9, 
  3.884265830212798*^9}},ExpressionUUID->"f18eb29d-99d0-47a1-8e4d-\
e593573b3fce"],

Cell["\<\
We already showed that any eventually periodic p-adic expansion is a rational \
number,\
\>", "Text",
 CellChangeTimes->{{3.8841733906746683`*^9, 3.8841734582038593`*^9}, {
  3.884212928676064*^9, 
  3.884212966850099*^9}},ExpressionUUID->"e8cd82cd-7841-4ecc-b79b-\
cb3bfb03423c"],

Cell[BoxData[
 RowBox[{" ", 
  RowBox[{"r", "=", 
   RowBox[{
    RowBox[{
     SubscriptBox[
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["a", "0"], 
        SubscriptBox["a", "1"], 
        SubscriptBox["a", "2"], 
        SubscriptBox["\[Ellipsis]a", 
         RowBox[{"j", "-", "1"}]]}], ")"}], "p"], "+", 
     RowBox[{
      SuperscriptBox["p", "j"], 
      SubscriptBox[
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["a", "j"], 
         SubscriptBox["a", 
          RowBox[{"j", "+", "1"}]], 
         SubscriptBox["a", 
          RowBox[{"j", "+", "2"}]], 
         SubscriptBox["\[Ellipsis]a", 
          RowBox[{"j", "+", "k", "-", "1"}]]}], ")"}], "p"], 
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox["p", "0"], "+", 
        SuperscriptBox["p", "k"], "+", 
        SuperscriptBox["p", 
         RowBox[{"2", "k"}]], "+", "\[Ellipsis]"}], ")"}]}]}], "=", 
    RowBox[{
     SubscriptBox[
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["a", "0"], 
        SubscriptBox["a", "1"], 
        SubscriptBox["a", "2"], 
        SubscriptBox["\[Ellipsis]a", 
         RowBox[{"j", "-", "1"}]]}], ")"}], "p"], "-", 
     RowBox[{
      SuperscriptBox["p", "j"], 
      SubscriptBox[
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["b", "0"], 
         SubscriptBox["b", "1"], 
         SubscriptBox["b", "2"], 
         SubscriptBox["\[Ellipsis]b", 
          RowBox[{"k", "-", "1"}]]}], ")"}], "p"], 
      FractionBox["1", 
       RowBox[{
        SuperscriptBox["p", "k"], "-", "1"}]]}]}]}]}]}]], "DisplayFormula",
 CellChangeTimes->{{3.883596514029295*^9, 3.883596639671094*^9}, {
  3.883596683629942*^9, 3.8835966935909863`*^9}, {3.883597004726803*^9, 
  3.883597064326984*^9}, {3.883664441049026*^9, 3.8836644746443853`*^9}, {
  3.883664508782503*^9, 3.883664673641151*^9}, {3.883664893025782*^9, 
  3.883665000985948*^9}, {3.8836650444589787`*^9, 3.883665052042808*^9}, {
  3.8840640697584*^9, 3.884064080173833*^9}, {3.88421285147473*^9, 
  3.884212884332026*^9}, {3.884272613971958*^9, 3.884272631420411*^9}, {
  3.884272757524378*^9, 
  3.88427276394788*^9}},ExpressionUUID->"d958d94f-432b-4a03-b09b-\
d4c7c3f19a61"],

Cell[TextData[{
 "To prove the converse, that every rational number r has an eventually \
periodic p-adic expansion, we will, perhaps surprisingly, focus on negative \
r. The p-adic expansion of a positive rational number can be obtained from \
its negative by negating. First, let\[CloseCurlyQuote]s discuss the internal ",
 StyleBox["PadicRationalNaive",
  FontSlant->"Italic"],
 " implementation. We have separate representations for each the \
non-repeating beginning part and the periodic part each with an index that \
encodes the length:"
}], "Text",
 CellChangeTimes->{{3.8841733906746683`*^9, 3.884173496118132*^9}, {
  3.8841840415394297`*^9, 3.884184043845977*^9}, {3.88418846271214*^9, 
  3.884188482705923*^9}, {3.8841904654435387`*^9, 3.8841904681438217`*^9}, {
  3.884190714808712*^9, 3.884190774111948*^9}, {3.8841911389009333`*^9, 
  3.8841911499809217`*^9}, {3.884191682243205*^9, 3.884191714687697*^9}, {
  3.884193486138736*^9, 3.884193487163241*^9}, {3.884213001976965*^9, 
  3.884213047217177*^9}, {3.884213702935266*^9, 3.884213703696732*^9}, {
  3.884214662124655*^9, 3.88421467031439*^9}, {3.884385232316906*^9, 
  3.884385253065426*^9}, {3.884385339371716*^9, 
  3.884385393555365*^9}},ExpressionUUID->"cef1a4ac-a88a-4152-b7fb-\
0492b4264038"],

Cell[TextData[{
 "Back to the problem of a general rational number with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"r", "<", 
    RowBox[{"-", "1"}]}], TraditionalForm]],ExpressionUUID->
  "7774049d-0136-4af3-b66a-41b2bdda034f"],
 ", hence there is an ",
 Cell[BoxData[
  FormBox[
   RowBox[{"N", ">", "0", " "}], TraditionalForm]],ExpressionUUID->
  "2ffe3f97-7d7e-4c66-aad6-3909712b60d8"],
 " such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"-", "1"}], "<=", 
    RowBox[{"r", "+", "N"}], "<", "0"}], TraditionalForm]],ExpressionUUID->
  "05c7ea39-d510-42b4-a542-28c7f2ad4a08"]
}], "Text",
 CellChangeTimes->{{3.8841733906746683`*^9, 3.8841734582038593`*^9}, {
  3.884212928676064*^9, 3.884212966850099*^9}, {3.884386471084116*^9, 
  3.884386521368062*^9}, {3.884386582160245*^9, 3.8843866132117167`*^9}, {
  3.884386699209682*^9, 3.884386722063632*^9}, {3.884386847359359*^9, 
  3.8843868542302647`*^9}, {3.884387059839566*^9, 
  3.8843870635557613`*^9}},ExpressionUUID->"19d1e901-6235-4d6e-b06b-\
093454467ab8"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"-", "1"}], "<=", " ", 
   RowBox[{"r", "+", "N"}]}], "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     SubscriptBox[
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["b", "0"], 
        SubscriptBox["b", "1"], 
        SubscriptBox["b", "2"], 
        SubscriptBox["\[Ellipsis]b", 
         RowBox[{"k", "-", "1"}]]}], ")"}], "p"], " ", 
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["p", "0"], "+", 
       SuperscriptBox["p", "k"], "+", 
       SuperscriptBox["p", 
        RowBox[{"2", "k"}]], "+", "\[Ellipsis]", "+", 
       SuperscriptBox["p", 
        RowBox[{"m", " ", "k"}]], "+", "\[Ellipsis]"}], ")"}]}], "<", 
    RowBox[{"0", "   ", "for", " ", "N"}]}], "=", 
   RowBox[{"-", 
    RowBox[{"Ceiling", "[", "r", "]"}]}]}]}]], "DisplayFormula",
 CellChangeTimes->{{3.883596514029295*^9, 3.883596639671094*^9}, {
  3.883596683629942*^9, 3.8835966935909863`*^9}, {3.883597004726803*^9, 
  3.883597064326984*^9}, {3.883664441049026*^9, 3.8836644746443853`*^9}, {
  3.883664508782503*^9, 3.883664673641151*^9}, {3.883664893025782*^9, 
