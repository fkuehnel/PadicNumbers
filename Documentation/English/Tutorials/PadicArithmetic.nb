Cell[BoxData[{
 RowBox[{"r", "=", 
  RowBox[{
   SubscriptBox[
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["a", "0"], 
      SubscriptBox["a", "1"], 
      SubscriptBox["a", "2"], 
      SubscriptBox["\[Ellipsis]a", 
       RowBox[{"j", "-", "1"}]]}], ")"}], "p"], "-", 
   RowBox[{
    SuperscriptBox["p", "j"], 
    SubscriptBox[
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["b", "0"], 
       SubscriptBox["b", "1"], 
       SubscriptBox["b", "2"], 
       SubscriptBox["\[Ellipsis]b", 
        RowBox[{"k", "-", "1"}]]}], ")"}], "p"], 
    FractionBox["1", 
     RowBox[{
      SuperscriptBox["p", "k"], "-", "1"}]]}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"(", 
   RowBox[{"-", "r"}], ")"}], "=", 
  RowBox[{"1", "+", 
   RowBox[{"(", 
    RowBox[{"-", "1"}], ")"}], "-", "r"}]}], "\[IndentingNewLine]", 
 RowBox[{"=", 
  RowBox[{
   RowBox[{"[", 
    RowBox[{"1", "+", 
     RowBox[{"(", 
      RowBox[{"p", "-", "1"}], ")"}], "-", 
     SubscriptBox["a", "0"]}], "]"}], "+", 
   RowBox[{
    UnderoverscriptBox["\[Sum]", 
     RowBox[{"m", "=", "1"}], 
     RowBox[{"j", "-", "1"}]], 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"p", "-", "1", "-", 
       SubscriptBox["a", "m"]}], ")"}], 
     SuperscriptBox["p", "m"]}]}], "-", 
   RowBox[{
    SuperscriptBox["p", "j"], 
    RowBox[{"(", 
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"m", "=", "0"}], 
       RowBox[{"k", "-", "1"}]], 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"p", "-", "1", "-", 
         SubscriptBox["b", "m"]}], ")"}], 
       SuperscriptBox["p", "m"]}]}], ")"}], 
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox["p", "0"], "+", 
      SuperscriptBox["p", "k"], "+", 
      SuperscriptBox["p", 
       RowBox[{"2", "k"}]], "+", "\[Ellipsis]"}], ")"}]}]}]}], "\[IndentingNewLine]", 
 RowBox[{"=", 
  RowBox[{
   RowBox[{"Mod", "[", 
    RowBox[{
     RowBox[{"-", 
      SubscriptBox[
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["a", "0"], 
         SubscriptBox["a", "1"], 
         SubscriptBox["a", "2"], 
         SubscriptBox["a", "3"], 
         SubscriptBox["\[Ellipsis]a", 
          RowBox[{"j", "-", "1"}]]}], ")"}], "p"]}], ",", 
     SuperscriptBox["p", "j"]}], "]"}], "-", 
   RowBox[{
    SuperscriptBox["p", "j"], " ", 
    FractionBox[
     RowBox[{"Mod", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "1"}], "-", 
        SubscriptBox[
         RowBox[{"(", 
          RowBox[{
           SubscriptBox["b", "0"], 
           SubscriptBox["b", "1"], 
           SubscriptBox["b", "2"], 
           SubscriptBox["\[Ellipsis]b", 
            RowBox[{"k", "-", "1"}]]}], ")"}], "p"]}], ",", 
       SuperscriptBox["p", "k"]}], "]"}], 
     RowBox[{
      SuperscriptBox["p", "k"], "-", "1"}]]}]}]}]}], "DisplayFormula",
 CellChangeTimes->{{3.883596514029295*^9, 3.883596639671094*^9}, {
   3.883596683629942*^9, 3.8835966935909863`*^9}, {3.883597004726803*^9, 
